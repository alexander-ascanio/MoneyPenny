@model MoneyPenny.ViewModels.Tickets.TicketListViewModel

@{
    ViewData["Title"] = "Tickets";

    string PriorityClass(string priority) => priority.ToLowerInvariant() switch
    {
        "critical" or "critica" or "crítica" => "ticket-pill-priority-critical",
        "high" or "alta" => "ticket-pill-priority-high",
        "low" or "baja" => "ticket-pill-priority-low",
        _ => "ticket-pill-priority-normal"
    };

    string StatusClass(string status) => status.ToLowerInvariant() switch
    {
        "resolved" or "closed" or "cerrado" or "resuelto" => "ticket-pill-status-closed",
        "in progress" or "en progreso" => "ticket-pill-status-progress",
        "new" or "nuevo" or "open" or "abierto" => "ticket-pill-status-open",
        _ => "ticket-pill-status-default"
    };

    string Truncate(string? value, int max = 40) =>
        string.IsNullOrWhiteSpace(value) ? "—" :
        value.Length <= max ? value : value[..(max - 1)] + "…";

    bool IsSelected(string? current, string value) =>
        string.Equals(current, value, StringComparison.Ordinal);

    var effectiveSortBy = string.IsNullOrWhiteSpace(Model.SortBy) ? TicketSort.Created : Model.SortBy!;

    bool IsSortActive(string column) =>
        string.Equals(effectiveSortBy, column, StringComparison.OrdinalIgnoreCase);

    string SortIconClass(string column) =>
        !IsSortActive(column)
            ? "bi-arrow-down-up tickets-sort-icon-muted"
            : string.Equals(Model.SortDir, "asc", StringComparison.OrdinalIgnoreCase)
                ? "bi-sort-up"
                : "bi-sort-down";
}

<div class="tickets-page">
    <div class="tickets-header">
        <div>
            <h2 class="tickets-title">
                <i class="bi bi-ticket-detailed"></i>
                Tickets
            </h2>
            <p class="tickets-subtitle text-muted mb-0">
                @if (string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    @:Listado de tickets TeamSupport
                    @if (Model.TotalCount > 0)
                    {
                        <span class="tickets-count-badge">@Model.TotalCount</span>
                    }
                }
                else
                {
                    @:No se pudo cargar el listado
                }
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    @if (TempData["WarningMessage"] is string warningMessage)
    {
        <div class="alert alert-warning border-0 shadow-sm">@warningMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm">@Model.ErrorMessage</div>
    }

    <form method="get" id="tickets-filter-form" asp-action="Index" asp-controller="Tickets">
        <div class="tickets-toolbar card border-0 shadow-sm">
            <div class="card-body py-3">
                <div class="row g-2 align-items-center">
                    <div class="col-lg-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="search" value="@Model.Search"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="Buscar por número, asunto o descripción" />
                        </div>
                    </div>
                    <div class="col-lg-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i> Buscar
                        </button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Search) || !string.IsNullOrWhiteSpace(Model.StatusFilter) || Model.Filters.HasAny)
                    {
                        <div class="col-lg-2">
                            <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="tickets-filters card border-0 shadow-sm">
            <div class="card-body py-3">
                <div class="tickets-filters-row">
                    <div class="tickets-filters-label">
                        <i class="bi bi-funnel"></i>
                        <span>Filtros</span>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-customer">Cliente:</label>
                        <select id="filter-customer" name="customer" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            <option value="">Todos</option>
                            @foreach (var option in Model.FilterOptions.Customers)
                            {
                                if (IsSelected(Model.Filters.Customer, option))
                                {
                                    <option value="@option" selected>@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-product">Producto:</label>
                        <select id="filter-product" name="product" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            <option value="">Todos</option>
                            @foreach (var option in Model.FilterOptions.Products)
                            {
                                if (IsSelected(Model.Filters.Product, option))
                                {
                                    <option value="@option" selected>@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-estado">Estado:</label>
                        <select id="filter-estado" name="estado" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            <option value="">Todos</option>
                            @foreach (var option in Model.FilterOptions.Statuses)
                            {
                                if (IsSelected(Model.Filters.Status, option))
                                {
                                    <option value="@option" selected>@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-priority">Prioridad:</label>
                        <select id="filter-priority" name="priority" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            <option value="">Todos</option>
                            @foreach (var option in Model.FilterOptions.Priorities)
                            {
                                if (IsSelected(Model.Filters.Priority, option))
                                {
                                    <option value="@option" selected>@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-rag">RAG:</label>
                        <select id="filter-rag" name="rag" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            @if (IsSelected(Model.Filters.Rag, ""))
                            {
                                <option value="" selected>Todos</option>
                            }
                            else
                            {
                                <option value="">Todos</option>
                            }
                            @if (IsSelected(Model.Filters.Rag, "true"))
                            {
                                <option value="true" selected>Indexado</option>
                            }
                            else
                            {
                                <option value="true">Indexado</option>
                            }
                            @if (IsSelected(Model.Filters.Rag, "false"))
                            {
                                <option value="false" selected>No indexado</option>
                            }
                            else
                            {
                                <option value="false">No indexado</option>
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-has-actions">Tickets con Acciones:</label>
                        <select id="filter-has-actions" name="hasActions" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            @if (IsSelected(Model.Filters.HasActions, ""))
                            {
                                <option value="" selected>Todos</option>
                            }
                            else
                            {
                                <option value="">Todos</option>
                            }
                            @if (IsSelected(Model.Filters.HasActions, "true"))
                            {
                                <option value="true" selected>Sí</option>
                            }
                            else
                            {
                                <option value="true">Sí</option>
                            }
                            @if (IsSelected(Model.Filters.HasActions, "false"))
                            {
                                <option value="false" selected>No</option>
                            }
                            else
                            {
                                <option value="false">No</option>
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-limit">Mostrar:</label>
                        <select id="filter-limit" name="limit" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            @if (IsSelected(Model.Filters.ResultLimit, "100"))
                            {
                                <option value="100" selected>Últimos 100</option>
                            }
                            else
                            {
                                <option value="100">Últimos 100</option>
                            }
                            @if (IsSelected(Model.Filters.ResultLimit, "200"))
                            {
                                <option value="200" selected>Últimos 200</option>
                            }
                            else
                            {
                                <option value="200">Últimos 200</option>
                            }
                            @if (IsSelected(Model.Filters.ResultLimit, "all"))
                            {
                                <option value="all" selected>Todos</option>
                            }
                            else
                            {
                                <option value="all">Todos</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="tickets-filters-row tickets-filters-row-secondary">
                    <div class="tickets-filters-align-spacer" aria-hidden="true">
                        <i class="bi bi-funnel"></i>
                        <span>Filtros</span>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-is-knowledge-base">IsKnowledgeBase:</label>
                        <select id="filter-is-knowledge-base" name="isKnowledgeBase" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            @if (IsSelected(Model.Filters.IsKnowledgeBase, ""))
                            {
                                <option value="" selected>Listado habitual</option>
                            }
                            else
                            {
                                <option value="">Listado habitual</option>
                            }
                            @if (IsSelected(Model.Filters.IsKnowledgeBase, "true"))
                            {
                                <option value="true" selected>Sí</option>
                            }
                            else
                            {
                                <option value="true">Sí</option>
                            }
                            @if (IsSelected(Model.Filters.IsKnowledgeBase, "false"))
                            {
                                <option value="false" selected>No</option>
                            }
                            else
                            {
                                <option value="false">No</option>
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-group-name">GroupName:</label>
                        <select id="filter-group-name" name="groupName" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            <option value="">Todos</option>
                            @foreach (var option in Model.FilterOptions.Groups)
                            {
                                if (IsSelected(Model.Filters.GroupName, option))
                                {
                                    <option value="@option" selected>@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="tickets-filter-item">
                        <label class="tickets-filter-label" for="filter-customer-name">CustomerName:</label>
                        <select id="filter-customer-name" name="customerName" class="form-select form-select-sm tickets-filter-select tickets-filter-auto">
                            <option value="">Todos</option>
                            @foreach (var option in Model.FilterOptions.Customers)
                            {
                                if (IsSelected(Model.Filters.CustomerName, option))
                                {
                                    <option value="@option" selected>@option</option>
                                }
                                else
                                {
                                    <option value="@option">@option</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <input type="hidden" name="sortBy" id="tickets-sort-by" value="@Model.SortBy" />
                <input type="hidden" name="sortDir" id="tickets-sort-dir" value="@Model.SortDir" />
            </div>
        </div>
    </form>

    <div class="tickets-table-card card border-0 shadow-sm mt-3">
        <div class="table-responsive">
            <table class="table tickets-table mb-0 align-middle" id="tickets-table">
                <colgroup>
                    <col data-col="number" style="width: 7rem;" />
                    <col data-col="subject" style="width: 18rem;" />
                    <col data-col="customer" style="width: 12rem;" />
                    <col data-col="status" style="width: 8rem;" />
                    <col data-col="priority" style="width: 8rem;" />
                    <col data-col="created" style="width: 10rem;" />
                    <col data-col="modified" style="width: 10rem;" />
                    <col data-col="indexed" style="width: 5rem;" />
                    <col data-col="rag" style="width: 4rem;" />
                    <col data-col="actions" style="width: 6rem;" />
                </colgroup>
                <thead>
                    <tr>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Number) ? " is-active" : "")" data-col="number" data-sort="@TicketSort.Number">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por número">
                                <span class="tickets-th-label">Número</span>
                                <i class="bi @SortIconClass(TicketSort.Number) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Número" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Subject) ? " is-active" : "")" data-col="subject" data-sort="@TicketSort.Subject">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por asunto">
                                <span class="tickets-th-label">Asunto</span>
                                <i class="bi @SortIconClass(TicketSort.Subject) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Asunto" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Customer) ? " is-active" : "")" data-col="customer" data-sort="@TicketSort.Customer">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por cliente">
                                <span class="tickets-th-label">Cliente</span>
                                <i class="bi @SortIconClass(TicketSort.Customer) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Cliente" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Status) ? " is-active" : "")" data-col="status" data-sort="@TicketSort.Status">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por estado">
                                <span class="tickets-th-label">Estado</span>
                                <i class="bi @SortIconClass(TicketSort.Status) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Estado" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Priority) ? " is-active" : "")" data-col="priority" data-sort="@TicketSort.Priority">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por prioridad">
                                <span class="tickets-th-label">Prioridad</span>
                                <i class="bi @SortIconClass(TicketSort.Priority) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Prioridad" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Created) ? " is-active" : "")" data-col="created" data-sort="@TicketSort.Created">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por fecha de creación">
                                <span class="tickets-th-label">Creado</span>
                                <i class="bi @SortIconClass(TicketSort.Created) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Creado" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable tickets-th-sortable@(IsSortActive(TicketSort.Modified) ? " is-active" : "")" data-col="modified" data-sort="@TicketSort.Modified">
                            <button type="button" class="tickets-th-sort-btn" aria-label="Ordenar por fecha de modificación">
                                <span class="tickets-th-label">Modificado</span>
                                <i class="bi @SortIconClass(TicketSort.Modified) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Modificado" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable text-center tickets-th-sortable@(IsSortActive(TicketSort.Indexed) ? " is-active" : "")" data-col="indexed" data-sort="@TicketSort.Indexed">
                            <button type="button" class="tickets-th-sort-btn tickets-th-sort-btn-center" aria-label="Ordenar por indexado">
                                <span class="tickets-th-label">Indexado</span>
                                <i class="bi @SortIconClass(TicketSort.Indexed) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Indexado" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable text-center tickets-th-sortable@(IsSortActive(TicketSort.Rag) ? " is-active" : "")" data-col="rag" data-sort="@TicketSort.Rag">
                            <button type="button" class="tickets-th-sort-btn tickets-th-sort-btn-center" aria-label="Ordenar por RAG">
                                <span class="tickets-th-label">RAG</span>
                                <i class="bi @SortIconClass(TicketSort.Rag) tickets-sort-icon" aria-hidden="true"></i>
                            </button>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna RAG" tabindex="0"></span>
                        </th>
                        <th class="tickets-th-resizable text-end" data-col="actions">
                            <span class="tickets-th-label">Acciones</span>
                            <span class="tickets-col-resizer" role="separator" aria-orientation="vertical" aria-label="Redimensionar columna Acciones" tabindex="0"></span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Tickets.Any())
                    {
                        <tr>
                            <td colspan="10" class="tickets-empty text-center">
                                @if (string.IsNullOrWhiteSpace(Model.ErrorMessage))
                                {
                                    <i class="bi bi-inbox display-6 d-block mb-2 text-muted"></i>
                                    <span>No hay tickets para mostrar.</span>
                                }
                                else
                                {
                                    <i class="bi bi-exclamation-circle display-6 d-block mb-2 text-danger"></i>
                                    <span>No se pudieron cargar los tickets.</span>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr class="tickets-row">
                            <td>
                                <a asp-action="Details" asp-route-id="@ticket.Id"
                                   class="ticket-number-link" title="Ver comentarios del ticket">
                                    <span class="ticket-number-link-inner">
                                        <span class="ticket-number-badge">#@ticket.Number</span>
                                        <span class="ticket-number-spinner spinner-border spinner-border-sm text-primary d-none"
                                              role="status" aria-hidden="true"></span>
                                    </span>
                                </a>
                            </td>
                            <td>
                                <div class="ticket-subject">@ticket.Title</div>
                            </td>
                            <td>
                                <span class="ticket-client">@Truncate(ticket.Customer, 28)</span>
                            </td>
                            <td>
                                <span class="ticket-pill @StatusClass(ticket.Status)">@ticket.Status</span>
                            </td>
                            <td>
                                <span class="ticket-pill @PriorityClass(ticket.Priority)">@ticket.Priority</span>
                            </td>
                            <td>
                                <div class="ticket-datetime">
                                    <i class="bi bi-calendar3 text-success"></i>
                                    <span>@ticket.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </td>
                            <td>
                                @if (ticket.UpdatedAt.HasValue)
                                {
                                    <div class="ticket-datetime">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                        <span>@ticket.UpdatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (ticket.IsFirstCommentIndexed)
                                {
                                    <span class="ticket-indexed-yes" title="Comentario #1 indexado (Índice #1)">
                                        <i class="bi bi-check-circle-fill"></i>
                                    </span>
                                }
                                else
                                {
                                    <span class="ticket-indexed-no" title="Comentario #1 sin indexar">
                                        <i class="bi bi-circle"></i>
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (ticket.IsIndexed)
                                {
                                    <span class="ticket-indexed-yes" title="Documento del ticket indexado para RAG">
                                        <i class="bi bi-check-circle-fill"></i>
                                    </span>
                                }
                                else
                                {
                                    <span class="ticket-indexed-no" title="Documento del ticket sin indexar">
                                        <i class="bi bi-circle"></i>
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="ticket-actions">
                                    <a asp-action="Details" asp-route-id="@ticket.Id"
                                       class="btn btn-ticket-view" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-controller="Rag" asp-action="Ask"
                                       asp-route-ticketId="@ticket.Id"
                                       asp-route-ticketNumber="@ticket.Number"
                                       class="btn btn-ticket-rag" title="Ver respuesta RAG">
                                        <i class="bi bi-robot"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/tickets-table.js" asp-append-version="true"></script>
    <script>
        (function () {
            const form = document.getElementById('tickets-filter-form');
            if (!form) return;

            form.querySelectorAll('.tickets-filter-auto').forEach(function (select) {
                select.addEventListener('change', function () {
                    if (typeof form.requestSubmit === 'function') {
                        form.requestSubmit();
                    } else {
                        form.submit();
                    }
                });
            });

            form.addEventListener('submit', function () {
                document.querySelector('.tickets-table-card')?.classList.add('tickets-loading');
            });

            if (typeof initTicketsColumnResize === 'function') {
                initTicketsColumnResize('tickets-table', 'moneypenny.tickets.columnWidths');
            }

            const sortByInput = document.getElementById('tickets-sort-by');
            const sortDirInput = document.getElementById('tickets-sort-dir');
            const table = document.getElementById('tickets-table');

            document.querySelectorAll('.ticket-number-link').forEach(function (link) {
                link.addEventListener('click', function () {
                    if (link.classList.contains('is-loading')) {
                        return;
                    }

                    link.classList.add('is-loading');
                    link.setAttribute('aria-busy', 'true');
                    link.querySelector('.ticket-number-spinner')?.classList.remove('d-none');
                });
            });

            window.addEventListener('pageshow', function (event) {
                if (!event.persisted) {
                    return;
                }

                document.querySelectorAll('.ticket-number-link').forEach(function (link) {
                    link.classList.remove('is-loading');
                    link.removeAttribute('aria-busy');
                    link.querySelector('.ticket-number-spinner')?.classList.add('d-none');
                });
            });

            if (form && sortByInput && sortDirInput && table) {
                table.querySelectorAll('th[data-sort]').forEach(function (th) {
                    const btn = th.querySelector('.tickets-th-sort-btn');
                    if (!btn) return;

                    btn.addEventListener('click', function () {
                        const column = th.dataset.sort;
                        if (!column) return;

                        if (sortByInput.value === column) {
                            sortDirInput.value = sortDirInput.value === 'asc' ? 'desc' : 'asc';
                        } else {
                            sortByInput.value = column;
                            sortDirInput.value = (column === 'created' || column === 'modified') ? 'desc' : 'asc';
                        }

                        document.querySelector('.tickets-table-card')?.classList.add('tickets-loading');
                        if (typeof form.requestSubmit === 'function') {
                            form.requestSubmit();
                        } else {
                            form.submit();
                        }
                    });
                });
            }
        })();
    </script>
}
