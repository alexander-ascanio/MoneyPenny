@model MoneyPenny.ViewModels.Tickets.TicketDetailViewModel

@{
    ViewData["Title"] = $"Ticket {Model.Number}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">@Model.Number — @Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">Detalle</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Estado</dt>
                    <dd class="col-sm-9">@Model.Status</dd>
                    <dt class="col-sm-3">Prioridad</dt>
                    <dd class="col-sm-9">@Model.Priority</dd>
                    <dt class="col-sm-3">Asignado</dt>
                    <dd class="col-sm-9">@(Model.Assignee ?? "Sin asignar")</dd>
                    <dt class="col-sm-3">Creado</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
                    <dt class="col-sm-3">Descripción</dt>
                    <dd class="col-sm-9"><pre class="mb-0">@Model.Description</pre></dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">Acciones RAG</div>
            <div class="card-body d-grid gap-2">
                <p class="text-muted mb-0">
                    Indexado:
                    @if (Model.IsIndexed)
                    {
                        <span class="badge text-bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">No</span>
                    }
                </p>
                <form asp-action="IndexTicket" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary w-100">Indexar ticket</button>
                </form>
                <a asp-controller="Rag" asp-action="Ask" asp-route-ticketId="@Model.Id" asp-route-ticketNumber="@Model.Number" class="btn btn-outline-success w-100">
                    Preguntar sobre este ticket
                </a>
            </div>
        </div>
    </div>
</div>
