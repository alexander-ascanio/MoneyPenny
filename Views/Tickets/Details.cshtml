@model MoneyPenny.ViewModels.Tickets.TicketDetailViewModel

@{
    ViewData["Title"] = $"Ticket {Model.Number}";

    string PriorityClass(string priority) => priority.ToLowerInvariant() switch
    {
        "critical" or "critica" or "crítica" => "ticket-pill-priority-critical",
        "high" or "alta" => "ticket-pill-priority-high",
        "low" or "baja" => "ticket-pill-priority-low",
        _ => "ticket-pill-priority-normal"
    };

    string StatusClass(string status) => status.ToLowerInvariant() switch
    {
        "resolved" or "closed" or "cerrado" or "resuelto" => "ticket-pill-status-closed",
        "in progress" or "en progreso" => "ticket-pill-status-progress",
        "new" or "nuevo" or "open" or "abierto" => "ticket-pill-status-open",
        _ => "ticket-pill-status-default"
    };

    string AttachmentProxyUrl(string originalUrl) =>
        Url.Action("Attachment", "Tickets", new { url = originalUrl }) ?? originalUrl;
}

<div class="tickets-page ticket-detail-page">
    <div class="ticket-detail-hero card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <span class="ticket-number-badge">#@Model.Number</span>
                        <span class="ticket-pill @StatusClass(Model.Status)">@Model.Status</span>
                        <span class="ticket-pill @PriorityClass(Model.Priority)">@Model.Priority</span>
                        @if (Model.IsFirstCommentIndexed)
                        {
                            <span class="badge rounded-pill text-bg-success">Indexado #1</span>
                        }
                    </div>
                    @{
                        var showTitleInHero = !Model.Comments.Any(c =>
                            !string.IsNullOrWhiteSpace(c.ActionType)
                            && string.Equals(c.ActionType, Model.Title, StringComparison.OrdinalIgnoreCase));
                    }
                    @if (showTitleInHero)
                    {
                        <h2 class="ticket-detail-title mb-1">@Model.Title</h2>
                    }
                    <p class="text-muted mb-0 small">
                        ID interno: @Model.Id
                        @if (!string.IsNullOrWhiteSpace(Model.TeamSupportId))
                        {
                            <span class="mx-2">·</span>
                            <span>TS: @Model.TeamSupportId</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.CodigoTelegestion))
                        {
                            <span class="mx-2">·</span>
                            <span>Cód. telegestión: @Model.CodigoTelegestion</span>
                        }
                    </p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
    }

    @if (TempData["WarningMessage"] is string warningMessage)
    {
        <div class="alert alert-warning border-0 shadow-sm">@warningMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm">@Model.ErrorMessage</div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h5 class="mb-0"><i class="bi bi-card-text me-2 text-primary"></i>Descripción</h5>
                </div>
                <div class="card-body">
                    <div class="ticket-description ticket-comment-body-html">
                        @Html.Raw(TicketHtmlHelper.PrepareCommentHtmlForDisplay(
                            Model.Description,
                            AttachmentProxyUrl))
                    </div>
                </div>
            </div>
            }

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <h5 class="mb-0">
                        <i class="bi bi-chat-left-text me-2 text-primary"></i>Comentarios
                        <span class="badge rounded-pill text-bg-light text-dark ms-1">@Model.Comments.Count</span>
                    </h5>
                </div>
                <div class="card-body">
                    @if (!Model.Comments.Any())
                    {
                        <div class="ticket-comments-empty text-muted text-center py-4">
                            <i class="bi bi-chat-dots display-6 d-block mb-2"></i>
                            <span>Este ticket no tiene comentarios registrados.</span>
                        </div>
                    }
                    else
                    {
                        var totalComments = Model.Comments.Count;
                        var commentIndex = 0;
                        <div class="ticket-comments-timeline">
                            @foreach (var comment in Model.Comments)
                            {
                                commentIndex++;
                                var commentNumber = totalComments - commentIndex + 1;
                                var hasContent = !string.IsNullOrWhiteSpace(comment.Content);
                                var isTicketSubjectAction = !string.IsNullOrWhiteSpace(comment.ActionType)
                                    && string.Equals(comment.ActionType, Model.Title, StringComparison.OrdinalIgnoreCase);
                                @if (isTicketSubjectAction)
                                {
                                    <div class="ticket-comment-date-marker">
                                        @comment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                    </div>
                                }
                                <article class="ticket-comment-card @(comment.IsVisible ? "ticket-comment-public" : "ticket-comment-internal")">
                                    @if (isTicketSubjectAction)
                                    {
                                        <div class="ticket-comment-subject-bar">@Model.Title</div>
                                    }
                                    <div class="ticket-comment-top">
                                        <div class="ticket-comment-top-left">
                                            <span class="ticket-comment-avatar">
                                                <i class="bi bi-person-fill"></i>
                                            </span>
                                            <div>
                                                <div class="ticket-comment-name">@comment.Author</div>
                                                <div class="ticket-comment-meta">
                                                    Comentario añadido el
                                                    <time datetime="@comment.CreatedAt.ToString("o")">
                                                        @comment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                    </time>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="ticket-comment-top-right">
                                            <div class="ticket-comment-number" aria-label="Comentario @commentNumber">@commentNumber</div>
                                            @if (comment.IsVisible)
                                            {
                                                <span class="ticket-comment-visibility ticket-comment-visibility-public">Public</span>
                                            }
                                            else
                                            {
                                                <span class="ticket-comment-visibility ticket-comment-visibility-internal">Interno</span>
                                            }
                                        </div>
                                    </div>
                                    <hr class="ticket-comment-divider" />
                                    @if (hasContent)
                                    {
                                        <div class="ticket-comment-body ticket-comment-body-html">
                                            @Html.Raw(TicketHtmlHelper.PrepareCommentHtmlForDisplay(comment.Content, AttachmentProxyUrl))
                                        </div>
                                    }
                                    @if (comment.Attachments.Any())
                                    {
                                        <div class="ticket-comment-attachments">
                                            @foreach (var attachment in comment.Attachments)
                                            {
                                                var proxyUrl = AttachmentProxyUrl(attachment.OriginalUrl);
                                                var label = attachment.FileName ?? "Adjunto";
                                                <a class="ticket-comment-attachment-link" href="@proxyUrl" target="_blank" rel="noopener">
                                                    <i class="bi bi-paperclip" aria-hidden="true"></i>
                                                    <span>@label</span>
                                                </a>
                                            }
                                        </div>
                                    }
                                    else if (comment.PendingAttachmentResolution)
                                    {
                                        <div class="ticket-comment-attachments ticket-comment-attachments-pending"
                                             data-action-id="@comment.TeamSupportActionId"
                                             data-ticket-id="@Model.TeamSupportId"
                                             data-content="@comment.Content">
                                            <span class="text-muted small">
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                                Buscando adjuntos en TeamSupport...
                                            </span>
                                        </div>
                                    }
                                    else if (!hasContent && !string.IsNullOrWhiteSpace(comment.ActionType))
                                    {
                                        <div class="ticket-comment-body ticket-comment-body-system text-muted">
                                            <i class="bi bi-gear me-1"></i>@comment.ActionType
                                        </div>
                                    }
                                    @if (comment.TimeSpentMinutes is > 0)
                                    {
                                        <div class="ticket-comment-footer text-muted small">
                                            <i class="bi bi-clock me-1"></i>@comment.TimeSpentMinutes.Value.ToString("0.##") min
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="ticket-info-tile card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="ticket-info-label"><i class="bi bi-building me-1"></i> Cliente</div>
                            <div class="ticket-info-value">@(Model.Customer ?? "—")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="ticket-info-tile card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="ticket-info-label"><i class="bi bi-people me-1"></i> Contactos</div>
                            <div class="ticket-info-value">@(Model.Contacts ?? "—")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="ticket-info-tile card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="ticket-info-label"><i class="bi bi-person-check me-1"></i> Asignado</div>
                            <div class="ticket-info-value">@(Model.Assignee ?? "Sin asignar")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="ticket-info-tile card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="ticket-info-label"><i class="bi bi-clock-history me-1"></i> Fechas</div>
                            <div class="ticket-info-value small">
                                <div class="ticket-datetime mb-1">
                                    <i class="bi bi-calendar3 text-success"></i>
                                    <span>Creado: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                @if (Model.UpdatedAt.HasValue)
                                {
                                    <div class="ticket-datetime">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                        <span>Modificado: @Model.UpdatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="ticket-rag-sidebar-sticky">
            <div class="card border-0 shadow-sm ticket-rag-panel">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h5 class="mb-0 d-flex align-items-center gap-1">
                        <span><i class="bi bi-robot me-2 text-success"></i>Acciones RAG</span>
                        <button type="button"
                                class="btn btn-link btn-sm p-0 rag-actions-help-btn"
                                data-bs-toggle="tooltip"
                                data-bs-placement="left"
                                data-bs-custom-class="rag-actions-tooltip"
                                data-bs-title="Vectorización: el comentario #1 del ticket se transforma en embeddings (vectores numéricos) y se almacena en PostgreSQL con pgvector.

Chunks: el texto se divide en fragmentos solapados para recuperar solo las partes más relevantes en cada consulta.

Al pulsar «Generar contexto», MoneyPenny busca los chunks más similares y los muestra como contexto recuperado.

RAG (Generación Aumentada por Recuperación) enriquece la respuesta de GPT con tickets similares ya indexados."
                                aria-label="Qué significa RAG">
                            <i class="bi bi-info-circle text-muted" aria-hidden="true"></i>
                        </button>
                    </h5>
                </div>
                <div class="card-body d-grid gap-3">
                    <a asp-action="Rag" asp-route-id="@Model.Id"
                       class="btn btn-success w-100 ticket-rag-response-link">
                        <span class="ticket-rag-response-label">
                            <i class="bi bi-play-fill me-1"></i> Iniciar acciones manualmente
                        </span>
                        <span class="ticket-rag-response-loading d-none">
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            Cargando…
                        </span>
                    </a>
                    <div class="alert alert-warning border-0 mb-0 d-none" id="notIndexedRagAlert" role="alert">
                        El comentario #1 de este ticket no está indexado. Indexa el comentario #1 desde Acciones RAG o Índice #1 antes de consultar la respuesta RAG.
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm ticket-rag-process-card mt-3">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h5 class="mb-0"><i class="bi bi-lightning-charge me-2 text-primary"></i>Procesamiento RAG (API)</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Indexa el ticket y genera la respuesta GPT con comprobación técnica (R1–R6).
                        Si hay capturas utilizables en el comentario #1, extrae su texto con Vision automáticamente.
                    </p>
                    <button type="button"
                            class="btn btn-primary w-100"
                            id="processTicketRagButton"
                            data-ticket-id="@Model.Id"
                            data-ticket-number="@Model.Number"
                            data-process-url="@Url.Action("ProcessTicket", "Rag")">
                        <span class="process-ticket-rag-label">
                            <i class="bi bi-play-fill me-1"></i> Indexar y generar respuesta GPT
                        </span>
                        <span class="process-ticket-rag-loading d-none">
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            Procesando…
                        </span>
                    </button>
                    <div class="alert alert-danger border-0 mt-3 mb-0 d-none" id="processTicketRagError" role="alert"></div>
                    <div class="d-none mt-3" id="processTicketRagResult">
                        <div class="ticket-rag-process-summary mb-2" id="processTicketRagSummary"></div>
                        <pre class="ticket-rag-process-json mb-0" id="processTicketRagJson"></pre>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm ticket-rag-panel mt-5">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h5 class="mb-0"><i class="bi bi-book me-2 text-primary"></i>Knowledge Base</h5>
                </div>
                <div class="card-body">
                    @if (Model.IsFirstCommentIndexed)
                    {
                        <a asp-controller="Rag" asp-action="Ask"
                           asp-route-ticketId="@Model.Id"
                           asp-route-ticketNumber="@Model.Number"
                           asp-route-knowledgeBaseOnly="true"
                           class="btn btn-outline-primary w-100 ticket-rag-response-link">
                            <span class="ticket-rag-response-label">
                                <i class="bi bi-book me-1"></i> Ver respuesta basada en KB
                            </span>
                            <span class="ticket-rag-response-loading d-none">
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                Cargando…
                            </span>
                        </a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-primary w-100" data-rag-blocked-button>
                            <i class="bi bi-book me-1"></i> Ver respuesta basada en KB
                        </button>
                    }
                </div>
            </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const notIndexedAlert = document.getElementById('notIndexedRagAlert');
            document.querySelectorAll('[data-rag-blocked-button]').forEach(function (button) {
                button.addEventListener('click', function () {
                    notIndexedAlert?.classList.remove('d-none');
                    notIndexedAlert?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                });
            });

            document.querySelectorAll('.ticket-rag-response-link').forEach(function (link) {
                link.addEventListener('click', function () {
                    if (link.classList.contains('is-loading')) {
                        return;
                    }

                    link.classList.add('is-loading');
                    link.setAttribute('aria-busy', 'true');
                    link.querySelector('.ticket-rag-response-label')?.classList.add('d-none');
                    link.querySelector('.ticket-rag-response-loading')?.classList.remove('d-none');
                });
            });

            window.addEventListener('pageshow', function (event) {
                if (!event.persisted) {
                    return;
                }

                document.querySelectorAll('.ticket-rag-response-link').forEach(function (link) {
                    link.classList.remove('is-loading');
                    link.removeAttribute('aria-busy');
                    link.querySelector('.ticket-rag-response-label')?.classList.remove('d-none');
                    link.querySelector('.ticket-rag-response-loading')?.classList.add('d-none');
                });
            });
        })();
    </script>

    <script>
        (function () {
            const button = document.getElementById('processTicketRagButton');
            if (!button) {
                return;
            }

            const label = button.querySelector('.process-ticket-rag-label');
            const loading = button.querySelector('.process-ticket-rag-loading');
            const resultBox = document.getElementById('processTicketRagResult');
            const summaryBox = document.getElementById('processTicketRagSummary');
            const jsonBox = document.getElementById('processTicketRagJson');
            const errorBox = document.getElementById('processTicketRagError');
            const processUrl = button.dataset.processUrl;
            const ticketId = button.dataset.ticketId;
            const ticketNumber = button.dataset.ticketNumber;

            function setLoading(isLoading) {
                button.disabled = isLoading;
                label?.classList.toggle('d-none', isLoading);
                loading?.classList.toggle('d-none', !isLoading);
            }

            function hideResult() {
                resultBox?.classList.add('d-none');
                errorBox?.classList.add('d-none');
            }

            function renderSummary(data) {
                if (!summaryBox) {
                    return;
                }

                const verdict = data.groundingCheck?.verdictLabel ?? data.groundingCheck?.verdict ?? '—';
                const score = data.groundingCheck?.score ?? '—';
                const chunks = data.indexing?.chunkCount ?? 0;
                const contextCount = data.gpt?.contextTicketCount ?? 0;
                const answerPreview = (data.gpt?.answer ?? '').slice(0, 180);

                summaryBox.innerHTML =
                    '<div class="small">' +
                    '<div><strong>Ticket:</strong> #' + (data.ticket?.number ?? '') + ' · ' + (data.ticket?.status ?? '') + '</div>' +
                    '<div><strong>Indexación:</strong> ' + chunks + ' chunks' +
                    (data.indexing?.processImages ? ' · imágenes procesadas' : '') + '</div>' +
                    '<div><strong>Contexto:</strong> ' + contextCount + ' ticket(s) similar(es)</div>' +
                    '<div><strong>Comprobación técnica:</strong> ' + verdict + ' (' + score + '/100)</div>' +
                    '<div class="text-muted mt-1">' + answerPreview + (data.gpt?.answer?.length > 180 ? '…' : '') + '</div>' +
                    '</div>';
            }

            async function runProcess() {
                hideResult();
                setLoading(true);

                try {
                    // processImages=true: el servidor decide si hay capturas utilizables (sin modal).
                    const params = new URLSearchParams({
                        ticketId: ticketId,
                        ticketNumber: ticketNumber,
                        processImages: 'true'
                    });
                    const response = await fetch(processUrl + '?' + params.toString(), {
                        method: 'GET',
                        headers: { 'Accept': 'application/json' }
                    });

                    const data = await response.json();
                    if (!response.ok || !data.success) {
                        throw new Error(data.errorMessage || 'No se pudo procesar el ticket.');
                    }

                    renderSummary(data);
                    if (jsonBox) {
                        jsonBox.textContent = JSON.stringify(data, null, 2);
                    }
                    resultBox?.classList.remove('d-none');
                } catch (error) {
                    if (errorBox) {
                        errorBox.textContent = error.message || 'Error inesperado al procesar el ticket.';
                        errorBox.classList.remove('d-none');
                    }
                } finally {
                    setLoading(false);
                }
            }

            button.addEventListener('click', function () {
                runProcess();
            });
        })();
    </script>

    <script>
        (function () {
            const pendingBlocks = document.querySelectorAll('.ticket-comment-attachments-pending');
            if (!pendingBlocks.length) {
                return;
            }

            pendingBlocks.forEach(async function (block) {
                const actionId = block.dataset.actionId;
                const ticketId = block.dataset.ticketId || '';
                const content = block.dataset.content || '';
                if (!actionId) {
                    block.remove();
                    return;
                }

                try {
                    const params = new URLSearchParams({
                        teamSupportActionId: actionId,
                        teamSupportTicketId: ticketId,
                        content: content
                    });
                    const response = await fetch(`/Tickets/ResolveActionAttachments?${params.toString()}`, {
                        headers: { 'Accept': 'application/json' }
                    });

                    if (!response.ok) {
                        throw new Error('resolve failed');
                    }

                    const attachments = await response.json();
                    if (!attachments.length) {
                        block.innerHTML = '<span class="text-muted small"><i class="bi bi-paperclip me-1"></i>Este comentario referencia un adjunto en TeamSupport que no está sincronizado. Configure ApiOrganizationId/ApiToken o AttachmentOverrides.</span>';
                        return;
                    }

                    block.classList.remove('ticket-comment-attachments-pending');
                    block.innerHTML = attachments.map(function (attachment) {
                        const label = attachment.fileName || 'Adjunto';
                        return `<a class="ticket-comment-attachment-link" href="${attachment.proxyUrl}" target="_blank" rel="noopener"><i class="bi bi-paperclip" aria-hidden="true"></i><span>${label}</span></a>`;
                    }).join('');
                } catch {
                    block.innerHTML = '<span class="text-muted small"><i class="bi bi-exclamation-circle me-1"></i>No se pudieron cargar los adjuntos de TeamSupport.</span>';
                }
            });
        })();
    </script>

}
