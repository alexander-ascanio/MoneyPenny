@model IReadOnlyList<MoneyPenny.ViewModels.Home.ApiFieldViewModel>

<div class="table-responsive">
    <table class="table table-sm api-field-table mb-0">
        <thead>
            <tr>
                <th>Campo</th>
                <th>Tipo</th>
                <th>Obligatorio</th>
                <th>Descripción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var field in Model)
            {
                <tr>
                    <td><code>@field.Name</code></td>
                    <td><span class="api-field-type">@field.Type</span></td>
                    <td>
                        @if (field.Required)
                        {
                            <span class="badge text-bg-danger-subtle border border-danger-subtle text-danger">Sí</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary-subtle border border-secondary-subtle text-secondary">No</span>
                        }
                    </td>
                    <td>@field.Description</td>
                </tr>
            }
        </tbody>
    </table>
</div>
