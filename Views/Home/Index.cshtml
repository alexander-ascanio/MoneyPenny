@{
    ViewData["Title"] = "Inicio";
}

<div class="home-page">
    <section class="home-hero mb-4 mb-lg-5">
        <div class="home-hero-glow home-hero-glow-1"></div>
        <div class="home-hero-glow home-hero-glow-2"></div>
        <div class="home-hero-inner">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    <span class="home-hero-badge">
                        <i class="bi bi-stars me-1"></i> Asistente RAG para soporte
                    </span>
                    <h1 class="home-title mb-3">MoneyPenny</h1>
                    <p class="home-hero-lead mb-4">
                        Portal interno para consultar tickets de <strong>TeamSupport</strong>, indexar el contenido
                        relevante del primer comentario y obtener respuestas asistidas con
                        <strong>RAG</strong> sobre tickets similares y la base de conocimiento.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Tickets" asp-action="Index" class="btn btn-light btn-lg home-hero-btn">
                            <i class="bi bi-ticket-detailed me-1"></i> Ver tickets
                        </a>
                        <a asp-controller="Rag" asp-action="FirstCommentIndex" class="btn btn-outline-light btn-lg home-hero-btn">
                            <i class="bi bi-journal-text me-1"></i> Índice #1
                        </a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="home-hero-stats">
                        <div class="home-stat-card home-stat-card-violet">
                            <i class="bi bi-search"></i>
                            <span>Búsqueda semántica</span>
                        </div>
                        <div class="home-stat-card home-stat-card-cyan">
                            <i class="bi bi-image"></i>
                            <span>Vision en capturas</span>
                        </div>
                        <div class="home-stat-card home-stat-card-amber">
                            <i class="bi bi-chat-square-text"></i>
                            <span>Respuestas GPT / KB</span>
                        </div>
                        <div class="home-stat-card home-stat-card-rose">
                            <i class="bi bi-shield-check"></i>
                            <span>Identity + roles</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4 mb-lg-5">
        <h2 class="home-section-title"><i class="bi bi-lightning-charge"></i> Qué hace</h2>
        <div class="row g-3 g-lg-4">
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-blue">
                    <div class="home-feature-icon"><i class="bi bi-list-ul"></i></div>
                    <h3 class="h6">Tickets TeamSupport</h3>
                    <p>Lista y filtra tickets sincronizados desde Azure PostgreSQL (solo lectura).</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-indigo">
                    <div class="home-feature-icon"><i class="bi bi-chat-left-text"></i></div>
                    <h3 class="h6">Detalle enriquecido</h3>
                    <p>Comentarios, adjuntos, imágenes embebidas y proxy autenticado de archivos.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-violet">
                    <div class="home-feature-icon"><i class="bi bi-diagram-3"></i></div>
                    <h3 class="h6">Índice vectorial</h3>
                    <p>Indexa el comentario #1 para búsqueda semántica con pgvector y embeddings OpenAI.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-teal">
                    <div class="home-feature-icon"><i class="bi bi-eye"></i></div>
                    <h3 class="h6">OpenAI Vision</h3>
                    <p>Extrae texto de capturas y filtra firmas, avisos legales y ruido de email.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-green">
                    <div class="home-feature-icon"><i class="bi bi-robot"></i></div>
                    <h3 class="h6">Respuestas RAG</h3>
                    <p>Sugerencias con GPT a partir de tickets similares o solo Knowledge Base.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-orange">
                    <div class="home-feature-icon"><i class="bi bi-sliders"></i></div>
                    <h3 class="h6">Indexación avanzada</h3>
                    <p>Indexación masiva, estimación de tokens y comparación de umbrales de similitud.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="home-feature-card home-feature-card-rose">
                    <div class="home-feature-icon"><i class="bi bi-shield-check"></i></div>
                    <h3 class="h6">Comprobación de respuesta</h3>
                    <p>Valida cada respuesta GPT con reglas R1–R6: contexto recuperado, datos técnicos, síntoma del cliente y proporcionalidad. Puntuación y veredicto sin coste de API.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4 mb-lg-5">
        <h2 class="home-section-title"><i class="bi bi-stack"></i> Stack tecnológico</h2>
        <div class="home-stack-grid">
            <span class="home-stack-pill home-stack-pill-net"><i class="bi bi-window"></i> ASP.NET Core MVC · .NET 10</span>
            <span class="home-stack-pill home-stack-pill-db"><i class="bi bi-database"></i> PostgreSQL + pgvector</span>
            <span class="home-stack-pill home-stack-pill-ef"><i class="bi bi-layers"></i> Entity Framework Core</span>
            <span class="home-stack-pill home-stack-pill-id"><i class="bi bi-person-badge"></i> ASP.NET Identity</span>
            <span class="home-stack-pill home-stack-pill-ui"><i class="bi bi-palette"></i> Bootstrap 5 + Razor</span>
            <span class="home-stack-pill home-stack-pill-ai"><i class="bi bi-cpu"></i> OpenAI API</span>
        </div>
    </section>

    <div class="row g-4 mb-4 mb-lg-5">
        <div class="col-lg-6">
            <section class="home-panel home-panel-databases h-100">
                <div class="home-panel-header">
                    <i class="bi bi-database-fill"></i>
                    <h2 class="h5 mb-0">Bases de datos</h2>
                </div>
                <div class="home-panel-body">
                    <article class="home-db-card home-db-card-app">
                        <div class="home-db-card-label">App</div>
                        <h3 class="h6">Aplicación <code>Database</code></h3>
                        <p>PostgreSQL local. Usuarios, roles, identidad y datos internos. Migraciones y seed al arranque.</p>
                    </article>
                    <article class="home-db-card home-db-card-ts">
                        <div class="home-db-card-label">Solo lectura</div>
                        <h3 class="h6">TeamSupport <code>TicketsDatabase</code></h3>
                        <p>Azure PostgreSQL. Tickets, acciones y HTML sincronizado. La app no escribe en esta base.</p>
                    </article>
                    <article class="home-db-card home-db-card-vec mb-0">
                        <div class="home-db-card-label">RAG</div>
                        <h3 class="h6">Vectores <code>VectorDatabase</code></h3>
                        <p>Chunks, embeddings, logs de consultas RAG y caché de texto extraído de imágenes.</p>
                    </article>
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="home-panel home-panel-integrations h-100">
                <div class="home-panel-header">
                    <i class="bi bi-plug-fill"></i>
                    <h2 class="h5 mb-0">Integraciones</h2>
                </div>
                <div class="home-panel-body">
                    <article class="home-int-card">
                        <div class="home-int-icon home-int-icon-ts"><i class="bi bi-headset"></i></div>
                        <div>
                            <h3 class="h6 mb-1">TeamSupport</h3>
                            <p class="mb-0">Lectura en Azure, proxy de adjuntos, resolución de URLs y overrides por acción. API REST opcional.</p>
                        </div>
                    </article>
                    <article class="home-int-card">
                        <div class="home-int-icon home-int-icon-ai"><i class="bi bi-stars"></i></div>
                        <div>
                            <h3 class="h6 mb-1">OpenAI</h3>
                            <p class="mb-0">Embeddings, chat <code>gpt-4o-mini</code> y Vision para capturas. Config en <code>ExternalApis:OpenAI</code> y <code>Rag</code>.</p>
                        </div>
                    </article>
                    <article class="home-int-card">
                        <div class="home-int-icon home-int-icon-grounding"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <h3 class="h6 mb-1">Comprobador de fundamentación</h3>
                            <p class="mb-0">
                                Tras generar la respuesta GPT en <code>/Rag/Ask</code>, evalúa si está anclada al contexto
                                (reglas R1–R6, puntuación 0–100, Pass/Warn/Fail). Motor local sin llamadas extra a OpenAI;
                                umbrales en <code>Rag:GroundingCheck</code>.
                            </p>
                        </div>
                    </article>
                    <article class="home-int-card mb-0">
                        <div class="home-int-icon home-int-icon-tools"><i class="bi bi-tools"></i></div>
                        <div>
                            <h3 class="h6 mb-1">Herramientas del portal</h3>
                            <p class="mb-0">
                                Indexación unitaria y masiva, estimación de tokens, umbrales RAG, usuarios (Admin) y
                                <a asp-controller="Tools" asp-action="Index" class="home-link">Herramientas</a>.
                            </p>
                        </div>
                    </article>
                </div>
            </section>
        </div>
    </div>

    <section class="home-cta">
        <div class="home-cta-glow"></div>
        <div class="home-cta-inner">
            <div>
                <h2 class="h4 mb-2">¿Listo para empezar?</h2>
                <p class="mb-0">Explora tickets, indexa comentarios y prueba las respuestas asistidas por IA.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Tickets" asp-action="Index" class="btn btn-light btn-lg">
                    <i class="bi bi-ticket-detailed me-1"></i> Ir a tickets
                </a>
                <a asp-controller="Rag" asp-action="FirstCommentIndex" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-journal-text me-1"></i> Indexar comentarios
                </a>
            </div>
        </div>
    </section>
</div>
