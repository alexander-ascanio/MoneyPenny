@model MoneyPenny.ViewModels.Rag.RagRatedAnswerDetailViewModel
@using MoneyPenny.Models.Rag
@using MoneyPenny.ViewModels.Rag

@{
    var response = Model.Response;

    (string Css, string Icon, string Label) ratingBadge = Model.Rating switch
    {
        RagQueryLog.RatingGood => ("text-bg-success", "bi-hand-thumbs-up", "OK"),
        RagQueryLog.RatingBad => ("text-bg-danger", "bi-hand-thumbs-down", "KO"),
        RagQueryLog.RatingNotAnswerable => ("text-bg-secondary", "bi-slash-circle", "No valorable"),
        _ => ("text-bg-light", "bi-question-circle", "Sin valorar")
    };

    string AttachmentProxyUrl(string originalUrl) =>
        Url.Action("Attachment", "Tickets", new { url = originalUrl }) ?? originalUrl;
}

<div class="rag-response-page">
    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
        <span class="badge @ratingBadge.Css"><i class="bi @ratingBadge.Icon me-1"></i>@ratingBadge.Label</span>
        @if (Model.RatedAt is not null)
        {
            <span class="text-muted small">Valorada el @Model.RatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        }
        @if (!string.IsNullOrWhiteSpace(response.TicketNumber))
        {
            <span class="text-muted small">· Ticket <strong>#@response.TicketNumber</strong></span>
            <a asp-controller="Rag" asp-action="Ask" asp-route-ticketId="@response.TicketId"
               target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary ms-auto">
                <i class="bi bi-box-arrow-up-right me-1"></i>Abrir vista completa
            </a>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(response.ErrorMessage))
    {
        <div class="alert alert-warning">@response.ErrorMessage</div>
    }

    @if (response.GptAnswerSavedAt is not null)
    {
        <div class="alert alert-info d-flex align-items-center mb-4" role="status">
            <i class="bi bi-clock-history me-2" aria-hidden="true"></i>
            <span>
                Respuesta guardada el
                <span class="text-muted">@response.GptAnswerSavedAt.Value.ToLocalTime().ToString("g")</span>
                (registro #@response.GptQueryLogId).
            </span>
        </div>
    }

    <div class="card shadow-sm mb-4@(response.GroundingReport?.Verdict == ResponseGroundingVerdict.Fail ? " border-start border-danger border-4" : "")">
        <div class="card-header rag-section-header">
            <i class="bi bi-robot me-2"></i>Respuesta @(response.KnowledgeBaseOnly ? "KnowledgeBase" : "GPT")
        </div>
        <div class="card-body">
            @if (string.IsNullOrWhiteSpace(response.Answer))
            {
                <p class="text-muted mb-0">No hay respuesta almacenada en este registro.</p>
            }
            else
            {
                <div class="rag-answer-text">@response.Answer.TrimEnd()</div>
            }
        </div>
    </div>

    @if (response.GroundingReport is not null)
    {
        <partial name="_RagGroundingCheck" model="response.GroundingReport" />
    }

    <div class="card shadow-sm mb-4 rag-context-card">
        <div class="card-header rag-section-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi @(response.KnowledgeBaseOnly ? "bi-book" : "bi-diagram-3") me-2"></i>
                @(response.KnowledgeBaseOnly ? "Contexto recuperado Knowledge Base" : "Contexto recuperado Tickets")
            </span>
        </div>
        <div class="card-body">
            @if (response.ContextItems.Any())
            {
                <p class="text-muted small mb-3">
                    Lista de @response.ContextItems.Count ticket(s) similar(es) recuperados ahora con la misma búsqueda que la vista de respuesta RAG.
                    Pulsa cada fila para ver el detalle. La puntuación indica similitud coseno (más alto = más relevante).
                </p>
                <div class="rag-context-list">
                    @foreach (var item in response.ContextItems)
                    {
                        <details class="rag-context-item">
                            <summary class="rag-context-item-summary">
                                <span class="rag-context-summary-main">
                                    <i class="bi bi-chevron-right rag-context-chevron" aria-hidden="true"></i>
                                    <a asp-controller="Tickets" asp-action="Details" asp-route-id="@item.TicketId"
                                       class="rag-context-ticket-link"
                                       target="_blank" rel="noopener"
                                       title="Abrir ticket en otra página"
                                       onclick="event.stopPropagation();">
                                        Ticket #@item.TicketNumber
                                    </a>
                                </span>
                                <span class="badge rag-score-badge">@item.Score.ToString("P1") similitud</span>
                            </summary>
                            <div class="rag-context-item-body">
                                @{
                                    var contextSnippet = response.KnowledgeBaseOnly
                                        ? KnowledgeBaseContextDisplayHelper.Format(item.Content) ?? item.Content
                                        : item.Content;
                                }
                                <pre class="rag-context-snippet mb-0">@contextSnippet</pre>
                            </div>
                        </details>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(Model.StoredContext))
            {
                <p class="text-muted small mb-3">Contexto almacenado con la respuesta en el momento de generarla.</p>
                <pre class="rag-context-snippet mb-0">@Model.StoredContext</pre>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    No se encontraron tickets similares ni hay contexto almacenado para esta respuesta.
                </div>
            }
        </div>
    </div>

    @if (response.KnowledgeBaseOnly && response.KnowledgeBaseSolution is not null)
    {
        <div class="card shadow-sm mb-4 rag-kb-solution-card">
            <div class="card-header rag-section-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-lightbulb me-2"></i>Respuesta KnowledgeBase</span>
                <span class="badge text-bg-success">Ticket #@response.KnowledgeBaseSolution.TicketNumber</span>
            </div>
            <div class="card-body">
                <pre class="rag-context-snippet mb-0">@response.KnowledgeBaseSolution.Text</pre>
            </div>
        </div>
    }

    @if (response.FirstComment is not null)
    {
        <div class="card shadow-sm mb-4 rag-reference-card">
            <div class="card-header rag-section-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-chat-left-quote me-2"></i>Primer comentario del ticket (indexado)</span>
                <span class="badge text-bg-secondary">Comentario #1</span>
            </div>
            <div class="card-body">
                <div class="rag-reference-meta text-muted small mb-2">
                    @response.FirstComment.Author · @response.FirstComment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </div>
                @if (!string.IsNullOrWhiteSpace(response.FirstComment.ImageExtractionWarning))
                {
                    <div class="alert alert-warning py-2 small mb-2">@response.FirstComment.ImageExtractionWarning</div>
                }
                <pre class="rag-context-snippet mb-0">@response.FirstComment.Content</pre>
            </div>
        </div>

        <div class="card shadow-sm mb-0">
            <div class="card-header rag-section-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-richtext me-2"></i>Comentario original</span>
                <span class="badge text-bg-secondary">Comentario #1</span>
            </div>
            <div class="card-body">
                <div class="rag-reference-meta text-muted small mb-2">
                    @response.FirstComment.Author · @response.FirstComment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </div>
                <div class="ticket-comment-body ticket-comment-body-html">
                    @Html.Raw(TicketHtmlHelper.PrepareCommentHtmlForDisplay(
                        response.FirstComment.OriginalContent,
                        AttachmentProxyUrl))
                </div>
                @if (response.FirstComment.Attachments.Any())
                {
                    <div class="ticket-comment-attachments">
                        @foreach (var attachment in response.FirstComment.Attachments)
                        {
                            var proxyUrl = AttachmentProxyUrl(attachment.OriginalUrl);
                            var label = attachment.FileName ?? "Adjunto";
                            <a class="ticket-comment-attachment-link" href="@proxyUrl" target="_blank" rel="noopener">
                                <i class="bi bi-paperclip" aria-hidden="true"></i>
                                <span>@label</span>
                            </a>
                        }
                    </div>
                }
                else if (response.FirstComment.PendingAttachmentResolution)
                {
                    <div class="ticket-comment-attachments">
                        <span class="text-muted small">
                            <i class="bi bi-paperclip me-1" aria-hidden="true"></i>
                            Este comentario referencia adjuntos en TeamSupport; ábrelo en la vista completa para resolverlos.
                        </span>
                    </div>
                }
            </div>
        </div>
    }
</div>
