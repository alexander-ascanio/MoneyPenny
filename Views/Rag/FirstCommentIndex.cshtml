@using System.Text.Json
@model MoneyPenny.ViewModels.Rag.FirstCommentIndexViewModel

@{
    ViewData["Title"] = "Índice de comentarios #1";
    var pricingJson = JsonSerializer.Serialize(new
    {
        charsPerToken = Model.PricingConfig.CharsPerToken,
        chunkSize = Model.PricingConfig.ChunkSize,
        chunkOverlap = Model.PricingConfig.ChunkOverlap,
        embeddingPricePerMillion = Model.PricingConfig.EmbeddingPricePerMillion,
        visionInputPricePerMillion = Model.PricingConfig.VisionInputPricePerMillion,
        visionOutputPricePerMillion = Model.PricingConfig.VisionOutputPricePerMillion,
        visionInputTokensPerImage = Model.PricingConfig.VisionInputTokensPerImage,
        visionOutputTokensPerImage = Model.PricingConfig.VisionOutputTokensPerImage,
        embeddingModel = Model.PricingConfig.EmbeddingModel,
        visionModel = Model.PricingConfig.VisionModel
    });
    var corpusJson = JsonSerializer.Serialize(new
    {
        totalTickets = Model.TotalTicketsWithFirstComment,
        pendingTickets = Model.PendingTickets,
        knowledgeBaseTotalTickets = Model.KnowledgeBaseTotalTicketsWithFirstComment,
        knowledgeBasePendingTickets = Model.KnowledgeBasePendingTickets,
        averageCommentCharCount = Model.AverageCommentCharCount,
        averageImagesPerTicket = Model.AverageImagesPerTicket,
        corpusSampleSize = Model.CorpusSampleSize
    });
}

<div class="mb-4">
    <h2 class="mb-2">
        <i class="bi bi-database-gear me-2 text-primary"></i>
        Índice masivo — comentario #1
    </h2>
    <p class="text-muted mb-0">
        Indexa el primer comentario (cliente) de cada ticket en la BD vectorial para búsqueda de casos similares.
    </p>
    @if (Model.CorpusSampleSize > 0)
    {
        <p class="text-muted small mb-0 mt-2" data-corpus-info>
            Muestra de @Model.CorpusSampleSize ticket(s): media ~@Model.AverageCommentCharCount.ToString("N0") caracteres/comentario,
            ~@Model.AverageImagesPerTicket.ToString("0.##") imagen(es)/ticket.
        </p>
    }
    else
    {
        <p class="text-muted small mb-0 mt-2" data-corpus-info>
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            Cargando estadísticas del corpus…
        </p>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    var alertClass = Model.LastResult?.TicketsFailed > 0
        ? "alert-danger"
        : !string.IsNullOrWhiteSpace(Model.LastResult?.ImageExtractionWarning)
            ? "alert-warning"
            : Model.LastResult?.TicketsIndexed > 0
                ? "alert-success"
                : "alert-warning";
    <div class="alert @alertClass">@Model.SuccessMessage</div>
}

<div class="mb-4">
    <h5 class="text-muted mb-3">
        <i class="bi bi-ticket-perforated me-1"></i>
        Tickets del listado
    </h5>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Con comentario #1</div>
                    <div class="display-6">@Model.TotalTicketsWithFirstComment</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-success">
                <div class="card-body">
                    <div class="text-muted small">Ya indexados</div>
                    <div class="display-6 text-success">@Model.IndexedTickets</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-warning">
                <div class="card-body">
                    <div class="text-muted small">Pendientes</div>
                    <div class="display-6 text-warning">@Model.PendingTickets</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-4">
    <h5 class="text-muted mb-3">
        <i class="bi bi-book me-1"></i>
        Knowledge Base
    </h5>
    <p class="text-muted small mb-3">
        Tickets con <code>IsKnowledgeBase = true</code>, grupo «Telematel – Knowledge Base» y cliente «TELEMATEL INTERNO» en TeamSupport.
        Los indexados cuentan solo si pertenecen a ese ámbito y tienen comentario #1 en la BD vectorial.
    </p>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-info">
                <div class="card-body">
                    <div class="text-muted small">Con comentario #1</div>
                    <div class="display-6 text-info">@Model.KnowledgeBaseTotalTicketsWithFirstComment</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-success">
                <div class="card-body">
                    <div class="text-muted small">Ya indexados</div>
                    <div class="display-6 text-success">@Model.KnowledgeBaseIndexedTickets</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-warning">
                <div class="card-body">
                    <div class="text-muted small">Pendientes</div>
                    <div class="display-6 text-warning">@Model.KnowledgeBasePendingTickets</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div data-bulk-index-estimate
     data-pricing="@pricingJson"
     data-corpus="@corpusJson"
     data-corpus-url="@Url.Action("FirstCommentCorpusStats")"
     data-bulk-count-url="@Url.Action("FirstCommentBulkCount")">
    <div id="bulkIndexProcessing"
         class="rag-gpt-processing d-none mb-4"
         role="status"
         aria-live="polite"
         data-start-url="@Url.Action("FirstCommentIndexStart")"
         data-progress-url="@Url.Action("FirstCommentIndexProgress")"
         data-result-url="@Url.Action("FirstCommentIndex")">
        <div class="rag-gpt-processing-spinner spinner-border text-primary" role="status" aria-hidden="true"></div>
        <div class="rag-gpt-processing-title" data-bulk-progress-title>Indexando comentarios #1…</div>
        <div class="rag-gpt-processing-subtitle text-muted small" data-bulk-progress-subtitle>
            Procesando tickets en segundo plano. No cierres esta pestaña hasta que finalice.
        </div>
        <div class="rag-index-progress-wrap w-100">
            <div class="progress rag-index-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                <div class="progress-bar progress-bar-striped progress-bar-animated" data-bulk-progress-bar style="width: 0%">0%</div>
            </div>
        </div>
        <div class="small text-muted mt-1" data-bulk-progress-stats></div>
    </div>

    <form asp-action="FirstCommentIndexStart" method="post" class="card shadow-sm" data-first-comment-bulk-form>
        <div class="card-header rag-section-header">Ejecutar indexación masiva</div>
        <div class="card-body">
            @Html.AntiForgeryToken()

            <div class="alert alert-info token-usage-estimate mb-3" data-bulk-estimate-output data-title="Estimación antes de ejecutar"></div>

            <div class="form-check mb-3">
                <input asp-for="SkipAlreadyIndexed" class="form-check-input" type="checkbox" id="skipAlreadyIndexed" data-bulk-skip-indexed />
                <label class="form-check-label" for="skipAlreadyIndexed">
                    Omitir tickets ya indexados
                </label>
                <div class="form-text">Recomendado para continuar una indexación interrumpida.</div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RebuildAll" class="form-check-input" type="checkbox" id="rebuildAll" data-bulk-rebuild />
                <label class="form-check-label" for="rebuildAll">
                    Reconstruir índice completo
                </label>
                <div class="form-text">Borra los chunks de comentarios #1 del ámbito seleccionado (listado de Tickets o Knowledge Base) antes de indexar de nuevo. No afecta al otro ámbito. Si está marcado, se ignoran los tickets ya indexados.</div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="OnlyKnowledgeBaseTickets" class="form-check-input" type="checkbox" id="onlyKnowledgeBaseTickets" data-bulk-only-knowledge-base />
                <label class="form-check-label" for="onlyKnowledgeBaseTickets">
                    Solo Tickets de la KnowledgeBase
                </label>
                <div class="form-text">Si está marcado, indexa solo tickets con <code>IsKnowledgeBase = true</code>, grupo «Telematel – Knowledge Base» y cliente «TELEMATEL INTERNO». Si no está marcado, indexa el ámbito del listado de Tickets (excluye esos casos).</div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="ProcessImages" class="form-check-input" type="checkbox" id="processImages" data-bulk-process-images />
                <label class="form-check-label" for="processImages">
                    Procesar imágenes con Vision (lento y consume tokens)
                </label>
                <div class="form-text">Por defecto solo texto HTML. Usa caché Vision si está disponible.</div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="TicketCreatedFrom" class="form-label"></label>
                    <input asp-for="TicketCreatedFrom" class="form-control" type="date" />
                    <span asp-validation-for="TicketCreatedFrom" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TicketCreatedTo" class="form-label"></label>
                    <input asp-for="TicketCreatedTo" class="form-control" type="date" />
                    <span asp-validation-for="TicketCreatedTo" class="text-danger"></span>
                </div>
            </div>
            <div class="form-text mb-3">
                Opcional. Filtra por la fecha de creación del ticket en TeamSupport (<code>tickets.CreatedAt</code>). Vacío = sin filtro de fechas.
            </div>

            <div class="mb-3">
                <label asp-for="MaxTickets" class="form-label">Límite de tickets (pruebas)</label>
                <input asp-for="MaxTickets" class="form-control" type="number" min="1" placeholder="Vacío = todos" data-bulk-max-tickets />
                <div class="form-text">Útil para probar con pocos tickets antes del volcado completo.</div>
            </div>

            <button type="submit" class="btn btn-primary" data-bulk-submit-button>
                <span class="bulk-submit-label">
                    <i class="bi bi-play-fill me-1"></i>Iniciar indexación
                </span>
                <span class="bulk-submit-loading d-none">
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    Iniciando…
                </span>
            </button>
            <a asp-controller="Tickets" asp-action="Index" class="btn btn-outline-secondary ms-2">Ver tickets</a>
        </div>
    </form>
</div>

<form asp-action="IndexFirstCommentTicket" method="post" class="card shadow-sm mt-4" data-first-comment-single-form>
    <div class="card-header rag-section-header">
        <i class="bi bi-ticket-detailed me-2"></i>Indexar un ticket concreto
    </div>
    <div class="card-body">
        @Html.AntiForgeryToken()

        <div id="singleIndexProcessing" class="rag-gpt-processing d-none mb-4" role="status" aria-live="polite">
            <div class="rag-gpt-processing-spinner spinner-border text-primary" role="status" aria-hidden="true"></div>
            <div class="rag-gpt-processing-title">Indexando comentario #1…</div>
            <div class="rag-gpt-processing-subtitle text-muted small">
                Generando chunks y embeddings. Puede tardar unos segundos.
            </div>
        </div>

        <p class="text-muted small">
            Indexa solo el comentario #1 del ticket indicado. Acepta el número con o sin <code>#</code> (ej. <code>142172</code>).
        </p>

        <div class="mb-3">
            <label asp-for="TargetTicketNumber" class="form-label"></label>
            <input asp-for="TargetTicketNumber" class="form-control" placeholder="Ej. 142172" />
            <span asp-validation-for="TargetTicketNumber" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="SkipAlreadyIndexedSingle" class="form-check-input" type="checkbox" id="skipAlreadyIndexedSingle" />
            <label class="form-check-label" for="skipAlreadyIndexedSingle">
                Omitir si ya está indexado
            </label>
            <div class="form-text">Solo aplica si no está marcada la reconstrucción del índice del ticket.</div>
        </div>

        <div class="form-check mb-3">
            <input asp-for="RebuildAllSingle" class="form-check-input" type="checkbox" id="rebuildAllSingle" />
            <label class="form-check-label" for="rebuildAllSingle">
                Reconstruir índice completo
            </label>
            <div class="form-text">Borra los chunks de comentario #1 de este ticket y lo indexa de nuevo (aunque ya existiera).</div>
        </div>

        <div class="form-check mb-3">
            <input asp-for="OnlyKnowledgeBaseTicketsSingle" class="form-check-input" type="checkbox" id="onlyKnowledgeBaseTicketsSingle" />
            <label class="form-check-label" for="onlyKnowledgeBaseTicketsSingle">
                Solo Tickets de la KnowledgeBase
            </label>
            <div class="form-text">Si está marcado, solo permite indexar tickets con <code>IsKnowledgeBase = true</code>, grupo «Telematel – Knowledge Base» y cliente «TELEMATEL INTERNO». Si no, solo tickets del listado habitual.</div>
        </div>

        <div class="form-check mb-3">
            <input asp-for="ProcessImagesSingle" class="form-check-input" type="checkbox" id="processImagesSingle" />
            <label class="form-check-label" for="processImagesSingle">
                Procesar imágenes con Vision (lento y consume tokens)
            </label>
        </div>

        <button type="submit" class="btn btn-outline-primary" data-single-submit-button>
            <span class="single-submit-label">
                <i class="bi bi-arrow-repeat me-1"></i>Indexar ticket
            </span>
            <span class="single-submit-loading d-none">
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                Indexando…
            </span>
        </button>
    </div>
</form>

@if (Model.LastRunEstimate is not null)
{
    <div class="mt-4">
        <partial name="_TokenUsageEstimate" model="Model.LastRunEstimate" />
    </div>
}

@if (Model.LastResult is not null)
{
    <div class="card shadow-sm mt-4">
        <div class="card-header">Resultado de la última ejecución</div>
        <div class="card-body">
            <ul class="mb-0">
                <li>Procesados: <strong>@Model.LastResult.TicketsProcessed</strong></li>
                <li>Indexados: <strong>@Model.LastResult.TicketsIndexed</strong></li>
                <li>Omitidos: <strong>@Model.LastResult.TicketsSkipped</strong></li>
                <li>Errores: <strong>@Model.LastResult.TicketsFailed</strong></li>
                <li>Chunks creados: <strong>@Model.LastResult.ChunksCreated</strong></li>
                <li>Embeddings creados: <strong>@Model.LastResult.EmbeddingsCreated</strong></li>
                @if (Model.LastResult.ProcessImages)
                {
                    <li>Imágenes detectadas: <strong>@Model.LastResult.ImagesDetected</strong></li>
                    <li>Imágenes con texto extraído: <strong>@Model.LastResult.ImagesExtracted</strong></li>
                }
            </ul>

            @if (!string.IsNullOrWhiteSpace(Model.LastResult.ImageExtractionWarning))
            {
                <div class="alert alert-warning mt-3 mb-0">
                    <strong>Vision:</strong> @Model.LastResult.ImageExtractionWarning
                </div>
            }

            @if (Model.LastResult.Errors.Any())
            {
                <div class="alert alert-danger mt-3 mb-0">
                    <ul class="mb-0 small">
                        @foreach (var error in Model.LastResult.Errors.Take(20))
                        {
                            <li>@error</li>
                        }
                    </ul>
                    @if (Model.LastResult.Errors.Count > 20)
                    {
                        <div class="small mt-2">… y @(Model.LastResult.Errors.Count - 20) error(es) más.</div>
                    }
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/rag-token-estimate.js" asp-append-version="true"></script>
    <script src="~/js/first-comment-index-progress.js" asp-append-version="true"></script>
    <script>
        (function () {
            const singleForm = document.querySelector('[data-first-comment-single-form]');
            if (singleForm) {
                singleForm.addEventListener('submit', function (event) {
                    const api = window.MoneyPennyFirstCommentIndex;
                    const single = api?.getSingleTicketsToIndex?.() ?? { count: 1, maySkip: false };
                    const ticketInput = document.getElementById('TargetTicketNumber');
                    const ticket = ticketInput?.value?.trim() || 'indicado';
                    const rebuild = document.getElementById('rebuildAllSingle')?.checked;

                    let message = `¿Indexar el comentario #1 del ticket ${ticket}?`;
                    message += `\n\nTickets a indexar: ${api?.formatTicketCount?.(single.count) ?? '1'}.`;
                    if (single.maySkip) {
                        message += '\n(Puede omitirse si el ticket ya está indexado.)';
                    }
                    if (rebuild) {
                        message += '\n\nSe eliminarán los chunks existentes de este ticket antes de indexar.';
                    }

                    if (!window.confirm(message)) {
                        event.preventDefault();
                        return;
                    }

                    const button = singleForm.querySelector('[data-single-submit-button]');
                    const label = button?.querySelector('.single-submit-label');
                    const loading = button?.querySelector('.single-submit-loading');
                    const processing = document.getElementById('singleIndexProcessing');

                    button.disabled = true;
                    label?.classList.add('d-none');
                    loading?.classList.remove('d-none');
                    processing?.classList.remove('d-none');
                    processing?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                });
            }
        })();
    </script>
}
