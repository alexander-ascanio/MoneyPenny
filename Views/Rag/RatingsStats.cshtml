@using System.Text.Json
@using MoneyPenny.Models.Rag
@model MoneyPenny.ViewModels.Rag.RagRatingsStatsViewModel

@{
    ViewData["Title"] = "Estadísticas de valoraciones";

    string FilterLabel(RagResponseType? type) => type switch
    {
        RagResponseType.Gpt => "GPT",
        RagResponseType.KnowledgeBase => "Knowledge Base",
        _ => "Todas"
    };

    (string Css, string Icon, string Label) RatingBadge(short rating) => rating switch
    {
        RagQueryLog.RatingGood => ("text-bg-success", "bi-hand-thumbs-up", "OK"),
        RagQueryLog.RatingBad => ("text-bg-danger", "bi-hand-thumbs-down", "KO"),
        RagQueryLog.RatingNotAnswerable => ("text-bg-secondary", "bi-slash-circle", "No valorable"),
        _ => ("text-bg-light", "bi-question-circle", "—")
    };

    var dailySeriesJson = JsonSerializer.Serialize(Model.DailySeries.Select(d => new
    {
        date = d.Date.ToString("yyyy-MM-dd"),
        good = d.GoodCount,
        bad = d.BadCount
    }));
}

<div class="rag-ratings-stats-page">
    <h2 class="mb-2">
        <i class="bi bi-bar-chart-line me-2 text-primary"></i>
        Estadísticas de valoraciones
    </h2>
    <p class="text-muted mb-4">
        Valoraciones de respuestas generadas registradas en <code>rag_query_logs</code>.
        Filtro actual: <strong>@FilterLabel(Model.ResponseType)</strong>
    </p>

    <div class="btn-group mb-4" role="group" aria-label="Filtro por tipo de respuesta">
        <a asp-action="RatingsStats"
           class="btn @(Model.ResponseType is null ? "btn-primary" : "btn-outline-primary")">Todas</a>
        <a asp-action="RatingsStats" asp-route-responseType="@RagResponseType.Gpt"
           class="btn @(Model.ResponseType == RagResponseType.Gpt ? "btn-primary" : "btn-outline-primary")">GPT</a>
        <a asp-action="RatingsStats" asp-route-responseType="@RagResponseType.KnowledgeBase"
           class="btn @(Model.ResponseType == RagResponseType.KnowledgeBase ? "btn-primary" : "btn-outline-primary")">Knowledge Base</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total valoradas</div>
                    <div class="fs-3 fw-bold">@Model.TotalCount.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-ES"))</div>
                    <div class="text-muted small">@Model.RatedCount valorables (OK + KO)</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card shadow-sm h-100 border-success">
                <div class="card-body">
                    <div class="text-success small"><i class="bi bi-hand-thumbs-up me-1"></i>OK (buenas)</div>
                    <div class="fs-3 fw-bold">@Model.GoodCount</div>
                    <div class="text-muted small">
                        @Model.GoodPercent.ToString("0.#") % del total
                        · <strong>@Model.GoodPercentExcludingNa.ToString("0.#") %</strong> sin no valorables
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card shadow-sm h-100 border-danger">
                <div class="card-body">
                    <div class="text-danger small"><i class="bi bi-hand-thumbs-down me-1"></i>KO (malas)</div>
                    <div class="fs-3 fw-bold">@Model.BadCount</div>
                    <div class="text-muted small">
                        @Model.BadPercent.ToString("0.#") % del total
                        · <strong>@Model.BadPercentExcludingNa.ToString("0.#") %</strong> sin no valorables
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card shadow-sm h-100 border-secondary">
                <div class="card-body">
                    <div class="text-secondary small"><i class="bi bi-slash-circle me-1"></i>No valorables</div>
                    <div class="fs-3 fw-bold">@Model.NotAnswerableCount</div>
                    <div class="text-muted small">@Model.NotAnswerablePercent.ToString("0.#") % del total</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.TotalCount > 0)
    {
        <div class="row g-3 mb-4">
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <i class="bi bi-pie-chart me-2"></i>Distribución total (OK / KO / No valorables)
                    </div>
                    <div class="card-body d-flex justify-content-center">
                        <div style="max-width: 320px; width: 100%;">
                            <canvas id="pieAll"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <i class="bi bi-pie-chart-fill me-2"></i>Solo valorables (OK / KO)
                    </div>
                    <div class="card-body d-flex justify-content-center">
                        <div style="max-width: 320px; width: 100%;">
                            @if (Model.RatedCount > 0)
                            {
                                <canvas id="pieRated"></canvas>
                            }
                            else
                            {
                                <p class="text-muted text-center my-5">No hay valoraciones OK/KO todavía.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span><i class="bi bi-graph-up me-2"></i>Evolución OK / KO (sin no valorables)</span>
                <div class="btn-group btn-group-sm" role="group" aria-label="Granularidad">
                    <button type="button" class="btn btn-outline-primary" data-granularity="day">Días</button>
                    <button type="button" class="btn btn-outline-primary" data-granularity="week">Semanas</button>
                    <button type="button" class="btn btn-primary" data-granularity="month">Meses</button>
                    <button type="button" class="btn btn-outline-primary" data-granularity="year">Años</button>
                </div>
            </div>
            <div class="card-body">
                @if (Model.DailySeries.Count > 0)
                {
                    <h6 class="text-muted">% sobre valorables</h6>
                    <div style="height: 320px;">
                        <canvas id="evolutionChart"></canvas>
                    </div>
                    <hr />
                    <h6 class="text-muted">Número de valoraciones</h6>
                    <div style="height: 320px;">
                        <canvas id="evolutionCountChart"></canvas>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center my-4 mb-0">No hay valoraciones OK/KO para dibujar la evolución.</p>
                }
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span>
                    <i class="bi bi-clock-history me-2"></i>Valoraciones
                    <span class="badge text-bg-secondary ms-1">
                        <span id="ratingsVisibleCount">@Model.RecentItems.Count</span> de @Model.RecentItems.Count
                    </span>
                </span>
            </div>
            <div class="card-body border-bottom py-3">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-lg-5">
                        <label for="ratingsSearchInput" class="form-label small text-muted mb-1">Buscar</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="search" class="form-control" id="ratingsSearchInput"
                                   placeholder="Ticket, respuesta, tipo, OK/KO…" autocomplete="off" />
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <label for="ratingsDateFrom" class="form-label small text-muted mb-1">Desde</label>
                        <input type="date" class="form-control form-control-sm" id="ratingsDateFrom" />
                    </div>
                    <div class="col-6 col-lg-3">
                        <label for="ratingsDateTo" class="form-label small text-muted mb-1">Hasta</label>
                        <input type="date" class="form-control form-control-sm" id="ratingsDateTo" />
                    </div>
                    <div class="col-12 col-lg-1 d-grid">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="ratingsClearFilters"
                                title="Limpiar filtros">
                            <i class="bi bi-x-circle me-1"></i>Limpiar
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="recentRatingsTable">
                        <thead>
                            <tr>
                                <th role="button" data-sort-key="rating">Valoración <i class="bi bi-arrow-down-up sort-icon text-muted"></i></th>
                                <th role="button" data-sort-key="ticket">Ticket <i class="bi bi-arrow-down-up sort-icon text-muted"></i></th>
                                <th role="button" data-sort-key="type">Tipo <i class="bi bi-arrow-down-up sort-icon text-muted"></i></th>
                                <th role="button" data-sort-key="answer">Respuesta <i class="bi bi-arrow-down-up sort-icon text-muted"></i></th>
                                <th role="button" data-sort-key="date">Fecha <i class="bi bi-arrow-down-up sort-icon text-muted"></i></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RecentItems)
                            {
                                var badge = RatingBadge(item.Rating);
                                var typeLabel = item.ResponseType == RagResponseType.KnowledgeBase ? "KB" : item.ResponseType.ToString();
                                <tr role="button"
                                    data-query-log-id="@item.QueryLogId"
                                    data-rating="@item.Rating"
                                    data-rating-label="@badge.Label"
                                    data-ticket="@(item.TicketNumber ?? "")"
                                    data-type="@typeLabel"
                                    data-answer="@item.AnswerExcerpt"
                                    data-date="@(item.RatedAt?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm:ss") ?? "")">
                                    <td>
                                        <span class="badge @badge.Css"><i class="bi @badge.Icon me-1"></i>@badge.Label</span>
                                    </td>
                                    <td class="text-nowrap">
                                        @if (!string.IsNullOrEmpty(item.TicketNumber))
                                        {
                                            <span class="fw-semibold">#@item.TicketNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@typeLabel</td>
                                    <td class="small">@item.AnswerExcerpt</td>
                                    <td class="text-muted small text-nowrap">
                                        @(item.RatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")
                                    </td>
                                    <td class="text-end">
                                        @if (item.TicketId is int ticketId)
                                        {
                                            <a asp-action="Ask" asp-route-ticketId="@ticketId"
                                               class="btn btn-sm btn-outline-primary text-nowrap">
                                                <i class="bi bi-box-arrow-up-right me-1"></i>Ver ticket
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div id="ratingsNoResults" class="text-center text-muted py-4 d-none">
                    <i class="bi bi-search me-1"></i>Ninguna valoración coincide con los filtros.
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Todavía no hay respuestas valoradas para este filtro.
        </div>
    }
</div>

<div class="modal fade" id="ratedAnswerModal" tabindex="-1" aria-labelledby="ratedAnswerModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ratedAnswerModalTitle">
                    <i class="bi bi-robot me-2 text-success"></i>Respuesta RAG
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="ratedAnswerModalLoading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="text-muted small mt-2">Recuperando respuesta y contexto…</div>
                </div>
                <div id="ratedAnswerModalContent" class="d-none"></div>
                <div id="ratedAnswerModalError" class="alert alert-warning d-none mb-0"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <script>
        (function () {
            const colors = {
                good: '#198754',
                bad: '#dc3545',
                notAnswerable: '#6c757d'
            };

            const totals = {
                good: @Model.GoodCount,
                bad: @Model.BadCount,
                notAnswerable: @Model.NotAnswerableCount
            };

            const percentLabel = (value, total) =>
                total === 0 ? '0 %' : (value * 100 / total).toLocaleString('es-ES', { maximumFractionDigits: 1 }) + ' %';

            const pieTooltip = {
                callbacks: {
                    label: ctx => {
                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                        return ` ${ctx.label}: ${ctx.parsed.toLocaleString('es-ES')} (${percentLabel(ctx.parsed, total)})`;
                    }
                }
            };

            // Etiquetas alrededor del pastel: "Etiqueta\ncontador (porcentaje)"
            const pieDataLabels = {
                anchor: 'end',
                align: 'end',
                offset: 6,
                clamp: true,
                display: ctx => ctx.dataset.data[ctx.dataIndex] > 0,
                formatter: (value, ctx) => {
                    const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                    return `${ctx.chart.data.labels[ctx.dataIndex]}\n${value.toLocaleString('es-ES')} (${percentLabel(value, total)})`;
                },
                textAlign: 'center',
                font: { weight: 'bold', size: 11 },
                color: '#212529'
            };

            const pieOptions = {
                // Deja aire para las etiquetas exteriores
                layout: { padding: 36 },
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: pieTooltip,
                    datalabels: pieDataLabels
                }
            };

            const pieAllCanvas = document.getElementById('pieAll');
            if (pieAllCanvas) {
                new Chart(pieAllCanvas, {
                    type: 'pie',
                    plugins: [ChartDataLabels],
                    data: {
                        labels: ['OK', 'KO', 'No valorables'],
                        datasets: [{
                            data: [totals.good, totals.bad, totals.notAnswerable],
                            backgroundColor: [colors.good, colors.bad, colors.notAnswerable]
                        }]
                    },
                    options: pieOptions
                });
            }

            const pieRatedCanvas = document.getElementById('pieRated');
            if (pieRatedCanvas) {
                new Chart(pieRatedCanvas, {
                    type: 'pie',
                    plugins: [ChartDataLabels],
                    data: {
                        labels: ['OK', 'KO'],
                        datasets: [{
                            data: [totals.good, totals.bad],
                            backgroundColor: [colors.good, colors.bad]
                        }]
                    },
                    options: pieOptions
                });
            }

            // --- Evolución: agregación cliente por día/semana/mes/año ---
            const dailySeries = @Html.Raw(dailySeriesJson);
            const evolutionCanvas = document.getElementById('evolutionChart');
            if (!evolutionCanvas || dailySeries.length === 0) {
                return;
            }

            const monthNames = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

            function isoWeek(date) {
                const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
                const dayNum = d.getUTCDay() || 7;
                d.setUTCDate(d.getUTCDate() + 4 - dayNum);
                const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
                const week = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
                return { year: d.getUTCFullYear(), week };
            }

            function bucketKeyAndLabel(dateStr, granularity) {
                const date = new Date(dateStr + 'T00:00:00');
                switch (granularity) {
                    case 'day':
                        return { key: dateStr, label: date.toLocaleDateString('es-ES') };
                    case 'week': {
                        const { year, week } = isoWeek(date);
                        const paddedWeek = String(week).padStart(2, '0');
                        return { key: `${year}-W${paddedWeek}`, label: `S${paddedWeek} ${year}` };
                    }
                    case 'year':
                        return { key: String(date.getFullYear()), label: String(date.getFullYear()) };
                    case 'month':
                    default: {
                        const paddedMonth = String(date.getMonth() + 1).padStart(2, '0');
                        return {
                            key: `${date.getFullYear()}-${paddedMonth}`,
                            label: `${monthNames[date.getMonth()]} ${date.getFullYear()}`
                        };
                    }
                }
            }

            function aggregate(granularity) {
                const buckets = new Map();
                for (const row of dailySeries) {
                    const { key, label } = bucketKeyAndLabel(row.date, granularity);
                    if (!buckets.has(key)) {
                        buckets.set(key, { label, good: 0, bad: 0 });
                    }
                    const bucket = buckets.get(key);
                    bucket.good += row.good;
                    bucket.bad += row.bad;
                }

                const keys = [...buckets.keys()].sort();
                return keys.map(k => {
                    const b = buckets.get(k);
                    const total = b.good + b.bad;
                    return {
                        label: b.label,
                        okPercent: total === 0 ? 0 : Math.round(b.good * 1000 / total) / 10,
                        koPercent: total === 0 ? 0 : Math.round(b.bad * 1000 / total) / 10,
                        good: b.good,
                        bad: b.bad
                    };
                });
            }

            const evolutionCountCanvas = document.getElementById('evolutionCountChart');
            let evolutionChart = null;
            let evolutionCountChart = null;

            function render(granularity) {
                const data = aggregate(granularity);
                const labels = data.map(d => d.label);

                if (evolutionChart) {
                    evolutionChart.destroy();
                }

                if (evolutionCountChart) {
                    evolutionCountChart.destroy();
                }

                evolutionChart = new Chart(evolutionCanvas, {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: '% OK',
                                data: data.map(d => d.okPercent),
                                borderColor: colors.good,
                                backgroundColor: colors.good,
                                tension: 0.2,
                                spanGaps: true
                            },
                            {
                                label: '% KO',
                                data: data.map(d => d.koPercent),
                                borderColor: colors.bad,
                                backgroundColor: colors.bad,
                                tension: 0.2,
                                spanGaps: true
                            }
                        ]
                    },
                    options: {
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        scales: {
                            y: {
                                min: 0,
                                max: 100,
                                ticks: { callback: value => value + ' %' }
                            }
                        },
                        plugins: {
                            legend: { position: 'bottom' },
                            tooltip: {
                                callbacks: {
                                    afterBody: items => {
                                        const d = data[items[0].dataIndex];
                                        return `OK: ${d.good.toLocaleString('es-ES')} · KO: ${d.bad.toLocaleString('es-ES')}`;
                                    }
                                }
                            }
                        }
                    }
                });

                evolutionCountChart = new Chart(evolutionCountCanvas, {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: 'OK',
                                data: data.map(d => d.good),
                                backgroundColor: colors.good
                            },
                            {
                                label: 'KO',
                                data: data.map(d => d.bad),
                                backgroundColor: colors.bad
                            }
                        ]
                    },
                    options: {
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            }
                        },
                        plugins: {
                            legend: { position: 'bottom' }
                        }
                    }
                });
            }

            const buttons = document.querySelectorAll('[data-granularity]');
            buttons.forEach(button => {
                button.addEventListener('click', () => {
                    buttons.forEach(b => b.classList.replace('btn-primary', 'btn-outline-primary'));
                    button.classList.replace('btn-outline-primary', 'btn-primary');
                    render(button.dataset.granularity);
                });
            });

            render('month');
        })();

        // --- Tabla de últimas valoraciones: ordenación y modal de detalle ---
        (function () {
            const table = document.getElementById('recentRatingsTable');
            if (!table) {
                return;
            }

            const tbody = table.querySelector('tbody');
            let currentKey = null;
            let currentAsc = true;

            function cellValue(row, key) {
                const raw = row.dataset[key] ?? '';
                if (key === 'rating') {
                    return parseInt(raw, 10) || 0;
                }
                if (key === 'ticket') {
                    const asNumber = parseInt(raw, 10);
                    return isNaN(asNumber) ? -1 : asNumber;
                }
                if (key === 'date') {
                    return raw === '' ? 0 : new Date(raw).getTime();
                }
                return raw.toLowerCase();
            }

            table.querySelectorAll('th[data-sort-key]').forEach(th => {
                th.addEventListener('click', () => {
                    const key = th.dataset.sortKey;
                    currentAsc = currentKey === key ? !currentAsc : true;
                    currentKey = key;

                    table.querySelectorAll('th[data-sort-key] .sort-icon').forEach(icon => {
                        icon.className = 'bi bi-arrow-down-up sort-icon text-muted';
                    });
                    th.querySelector('.sort-icon').className =
                        `bi ${currentAsc ? 'bi-arrow-up' : 'bi-arrow-down'} sort-icon text-primary`;

                    const rows = [...tbody.querySelectorAll('tr')];
                    rows.sort((a, b) => {
                        const va = cellValue(a, key);
                        const vb = cellValue(b, key);
                        const cmp = va < vb ? -1 : va > vb ? 1 : 0;
                        return currentAsc ? cmp : -cmp;
                    });
                    rows.forEach(r => tbody.appendChild(r));
                });
            });

            // --- Filtros: buscador de texto y rango de fechas ---
            const searchInput = document.getElementById('ratingsSearchInput');
            const dateFromInput = document.getElementById('ratingsDateFrom');
            const dateToInput = document.getElementById('ratingsDateTo');
            const clearButton = document.getElementById('ratingsClearFilters');
            const visibleCount = document.getElementById('ratingsVisibleCount');
            const noResults = document.getElementById('ratingsNoResults');

            function applyFilters() {
                const query = (searchInput.value ?? '').trim().toLowerCase();
                const terms = query.split(/\s+/).filter(t => t.length > 0);
                const from = dateFromInput.value ? new Date(dateFromInput.value + 'T00:00:00') : null;
                const to = dateToInput.value ? new Date(dateToInput.value + 'T23:59:59') : null;

                let visible = 0;
                tbody.querySelectorAll('tr[data-query-log-id]').forEach(row => {
                    let show = true;

                    if (from || to) {
                        const raw = row.dataset.date;
                        const date = raw ? new Date(raw) : null;
                        if (!date) {
                            show = false;
                        } else {
                            if (from && date < from) show = false;
                            if (to && date > to) show = false;
                        }
                    }

                    if (show && terms.length > 0) {
                        const haystack = [
                            row.dataset.ticket ? '#' + row.dataset.ticket : '',
                            row.dataset.ratingLabel,
                            row.dataset.type,
                            row.dataset.answer,
                            row.dataset.date ? new Date(row.dataset.date).toLocaleDateString('es-ES') : ''
                        ].join(' ').toLowerCase();
                        show = terms.every(term => haystack.includes(term));
                    }

                    row.classList.toggle('d-none', !show);
                    if (show) visible++;
                });

                visibleCount.textContent = String(visible);
                noResults.classList.toggle('d-none', visible > 0);
            }

            searchInput.addEventListener('input', applyFilters);
            dateFromInput.addEventListener('change', applyFilters);
            dateToInput.addEventListener('change', applyFilters);
            clearButton.addEventListener('click', () => {
                searchInput.value = '';
                dateFromInput.value = '';
                dateToInput.value = '';
                applyFilters();
            });

            const modalElement = document.getElementById('ratedAnswerModal');
            const modal = new bootstrap.Modal(modalElement);
            const loading = document.getElementById('ratedAnswerModalLoading');
            const content = document.getElementById('ratedAnswerModalContent');
            const errorBox = document.getElementById('ratedAnswerModalError');

            tbody.querySelectorAll('tr[data-query-log-id]').forEach(row => {
                row.addEventListener('click', async event => {
                    if (event.target.closest('a')) {
                        return; // No abrir el modal al pulsar «Ver ticket».
                    }

                    const queryLogId = row.dataset.queryLogId;
                    const ticket = row.dataset.ticket;

                    document.getElementById('ratedAnswerModalTitle').innerHTML =
                        '<i class="bi bi-robot me-2 text-success"></i>Respuesta RAG' +
                        (ticket ? ` — Ticket #${ticket}` : '');
                    loading.classList.remove('d-none');
                    content.classList.add('d-none');
                    content.innerHTML = '';
                    errorBox.classList.add('d-none');
                    modal.show();

                    try {
                        const response = await fetch(`@Url.Action("RatedAnswerDetail")?queryLogId=${queryLogId}`,
                            { headers: { 'Accept': 'text/html' } });
                        if (!response.ok) {
                            throw new Error(`HTTP ${response.status}`);
                        }

                        content.innerHTML = await response.text();
                        loading.classList.add('d-none');
                        content.classList.remove('d-none');
                    } catch (err) {
                        loading.classList.add('d-none');
                        errorBox.textContent = 'No se pudo cargar el detalle: ' + err.message;
                        errorBox.classList.remove('d-none');
                    }
                });
            });
        })();
    </script>
}
