@model MoneyPenny.ViewModels.Rag.AskTicketViewModel

@{
    ViewData["Title"] = "Consulta RAG";
}

<h2 class="mb-4">
    <i class="bi bi-robot me-2"></i>
    Consulta RAG
</h2>

@if (!string.IsNullOrWhiteSpace(Model.TicketNumber))
{
    <p class="text-muted">Contexto del ticket: <strong>@Model.TicketNumber</strong></p>
}

<form asp-action="Ask" method="post" class="card shadow-sm">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TicketId" />
        <input type="hidden" asp-for="TicketNumber" />
        <div class="mb-3">
            <label asp-for="Question" class="form-label"></label>
            <textarea asp-for="Question" class="form-control" rows="4" placeholder="Escribe tu pregunta sobre los tickets indexados..."></textarea>
            <span asp-validation-for="Question" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Enviar pregunta</button>
        <a asp-controller="Tickets" asp-action="Index" class="btn btn-outline-secondary ms-2">Ver tickets</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
