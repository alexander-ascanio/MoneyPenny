@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = null;
    var reason = User.FindFirst("hubrd_reason")?.Value ?? "";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                    ?? User.FindFirst("email")?.Value
                    ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso Denegado - MoneyPenny</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f0 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .access-card {
            max-width: 480px;
            width: 100%;
            border: none;
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }
        .access-header {
            background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
            padding: 2.5rem 2rem 2rem;
            text-align: center;
            color: white;
        }
        .access-header .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }
        .access-header .icon-circle i {
            font-size: 2.2rem;
        }
        .access-body {
            padding: 2rem;
            text-align: center;
        }
        .user-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 2rem;
            padding: 0.35rem 1rem;
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 1.25rem;
        }
        .reason-text {
            color: #495057;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 0;
        }
        .divider {
            border-top: 1px solid #e9ecef;
            margin: 1.5rem 0;
        }
        .access-footer {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
        }
    </style>
</head>
<body>
    <div class="card access-card">
        <div class="access-header">
            <div class="icon-circle">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="fw-bold mb-1">Acceso Denegado</h2>
            <p class="mb-0 opacity-75" style="font-size: 0.9rem;">MoneyPenny — Telematel</p>
        </div>
        <div class="access-body">
            @if (!string.IsNullOrEmpty(userEmail))
            {
                <div class="user-badge">
                    <i class="bi bi-person-circle"></i>
                    @userEmail
                </div>
            }

            @if (reason == "no_access")
            {
                <p class="reason-text">
                    Tu cuenta no tiene permisos para acceder a <strong>MoneyPenny</strong>.<br />
                    Contacta con tu administrador para solicitar acceso.
                </p>
            }
            else if (reason == "user_not_found")
            {
                <p class="reason-text">
                    Tu email no está registrado en el sistema de permisos.<br />
                    Verifica que hayas iniciado sesión con tu cuenta corporativa.
                </p>
            }
            else if (reason == "api_error")
            {
                <div class="alert alert-warning d-inline-flex align-items-center gap-2 py-2 px-3 mb-3" role="alert" style="font-size: 0.85rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Error temporal de verificación
                </div>
                <p class="reason-text">
                    No se ha podido verificar tu acceso en este momento.<br />
                    Inténtalo de nuevo en unos minutos.
                </p>
            }
            else
            {
                <p class="reason-text">
                    No tienes permisos para acceder a este recurso.
                </p>
            }

            <div class="divider"></div>

            <div class="access-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">
                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                    </a>
                    @if (reason == "api_error")
                    {
                        <a href="/" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-clockwise me-1"></i>Reintentar
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Welcome" class="btn btn-danger">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesión
                    </a>
                }
            </div>
        </div>
    </div>
</body>
</html>
