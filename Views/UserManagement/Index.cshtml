@model IEnumerable<MoneyPenny.Models.UserManagementViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    var totalUsers = Model.Count();
    var adminUsers = Model.Count(u => u.Roles.Contains("Admin"));
    var activeUsers = Model.Count(u => u.User.LastLoginAt != null && u.User.LastLoginAt >= DateTime.UtcNow.AddDays(-30));
    var inactiveUsers = Model.Count(u => u.User.LastLoginAt == null || u.User.LastLoginAt < DateTime.UtcNow.AddDays(-30));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-people me-2" viewBox="0 0 16 16">
            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
        </svg>
        @ViewData["Title"]
    </h2>
    <div>
        <a asp-action="Create" class="btn btn-primary btn-lg me-2">
            <i class="bi bi-person-plus me-2"></i> Nuevo Usuario
        </a>
        <a asp-action="Roles" class="btn btn-secondary btn-lg">
            <i class="bi bi-shield-check me-2"></i> Gestionar Roles
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Tarjetas de Resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-primary shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-primary mb-0">@totalUsers</h3>
                <p class="text-muted mb-0">Total Usuarios</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-danger mb-0">@adminUsers</h3>
                <p class="text-muted mb-0">Administradores</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-success mb-0">@activeUsers</h3>
                <p class="text-muted mb-0">Activos (30 días)</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-warning shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-warning mb-0">@inactiveUsers</h3>
                <p class="text-muted mb-0">Inactivos</p>
            </div>
        </div>
    </div>
</div>

<!-- Búsqueda y Filtros -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold">Buscar</label>
                <input type="text" name="search" class="form-control" placeholder="Email o nombre..." value="@ViewData["SearchQuery"]">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Rol</label>
                <select name="roleFilter" class="form-select">
                    <option value="">Todos los roles</option>
                    <option value="Admin">Administradores</option>
                    <option value="User">Usuarios</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Estado</label>
                <select name="statusFilter" class="form-select">
                    <option value="">Todos</option>
                    <option value="active">Activos</option>
                    <option value="inactive">Inactivos</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Tabla de Usuarios -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tipo</th>
                        <th>Usuario</th>
                        <th>Roles</th>
                        <th>Fecha de Registro</th>
                        <th>Último Acceso</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-people" style="font-size: 3rem;"></i>
                                <p class="mt-2">No hay usuarios disponibles</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var isAdmin = item.Roles.Contains("Admin");
                            var isActive = item.User.LastLoginAt != null && item.User.LastLoginAt >= DateTime.UtcNow.AddDays(-30);
                            var typeClass = isAdmin ? "danger" : "primary";
                            var typeText = isAdmin ? "ADMIN" : "USER";
                            var statusClass = isActive ? "success" : "warning";
                            var statusText = isActive ? "Activo" : "Inactivo";
                            var statusIcon = isActive ? "check-circle-fill" : "clock";
                            var daysInactive = item.User.LastLoginAt.HasValue ? (DateTime.UtcNow - item.User.LastLoginAt.Value).Days : -1;
                            
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-@typeClass">
                                        <i class="bi bi-@(isAdmin ? "shield-fill-check" : "person") me-1"></i>
                                        @typeText
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-fill text-primary" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div>
                                            <strong>@item.User.DisplayName</strong>
                                            <br>
                                            <small class="text-muted">
                                                <i class="bi bi-envelope me-1"></i>
                                                @item.User.Email
                                            </small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @foreach (var role in item.Roles)
                                    {
                                        var roleBadgeClass = role == "Admin" ? "danger" : "primary";
                                        <span class="badge bg-@roleBadgeClass me-1">@role</span>
                                    }
                                </td>
                                <td>
                                    <i class="bi bi-calendar-plus me-1"></i>
                                    @item.User.CreatedAt.ToString("dd/MM/yyyy")
                                    <br>
                                    <small class="text-muted">@item.User.CreatedAt.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    @if (item.User.LastLoginAt.HasValue)
                                    {
                                        <i class="bi bi-clock-history me-1"></i>
                                        @item.User.LastLoginAt.Value.ToString("dd/MM/yyyy")
                                        <br>
                                        <small class="text-muted">
                                            @if (daysInactive == 0)
                                            {
                                                <span class="text-success">Hoy</span>
                                            }
                                            else if (daysInactive == 1)
                                            {
                                                <span>Hace 1 día</span>
                                            }
                                            else
                                            {
                                                <span>Hace @daysInactive días</span>
                                            }
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            <i class="bi bi-dash-circle me-1"></i>
                                            Nunca
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-@statusClass">
                                        <i class="bi bi-@statusIcon me-1"></i>
                                        @statusText
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#viewModal@(item.User.Id)" title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <a asp-action="Edit" asp-route-id="@item.User.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (!isAdmin || adminUsers > 1)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('@item.User.Id', '@item.User.DisplayName')" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Último administrador">
                                                <i class="bi bi-lock"></i>
                                            </button>
                                        }
                                    </div>
                                    
                                    <!-- Modal de Vista -->
                                    <div class="modal fade" id="viewModal@(item.User.Id)" tabindex="-1">
                                        <div class="modal-dialog modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">
                                                        <i class="bi bi-person-circle me-2"></i>
                                                        Detalles del Usuario
                                                    </h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <dl class="row">
                                                                <dt class="col-sm-5">Nombre:</dt>
                                                                <dd class="col-sm-7">@item.User.DisplayName</dd>
                                                                
                                                                <dt class="col-sm-5">Email:</dt>
                                                                <dd class="col-sm-7">@item.User.Email</dd>
                                                                
                                                                <dt class="col-sm-5">Tipo:</dt>
                                                                <dd class="col-sm-7"><span class="badge bg-@typeClass">@typeText</span></dd>
                                                                
                                                                <dt class="col-sm-5">Roles:</dt>
                                                                <dd class="col-sm-7">
                                                                    @foreach (var role in item.Roles)
                                                                    {
                                                                        var roleBadgeClass = role == "Admin" ? "danger" : "primary";
                                                                        <span class="badge bg-@roleBadgeClass me-1">@role</span>
                                                                    }
                                                                </dd>
                                                            </dl>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <dl class="row">
                                                                <dt class="col-sm-6">Fecha de Registro:</dt>
                                                                <dd class="col-sm-6">@item.User.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                                                                
                                                                <dt class="col-sm-6">Último Acceso:</dt>
                                                                <dd class="col-sm-6">@(item.User.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</dd>
                                                                
                                                                <dt class="col-sm-6">Estado:</dt>
                                                                <dd class="col-sm-6"><span class="badge bg-@statusClass">@statusText</span></dd>
                                                                
                                                                <dt class="col-sm-6">ID:</dt>
                                                                <dd class="col-sm-6"><small class="text-muted">@item.User.Id</small></dd>
                                                            </dl>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                                    <a asp-action="Edit" asp-route-id="@item.User.Id" class="btn btn-primary">
                                                        <i class="bi bi-pencil me-1"></i> Editar
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas eliminar al usuario <strong id="deleteUserName"></strong>?</p>
                <p class="text-danger"><strong>Esta acción no se puede deshacer.</strong></p>
                <p class="text-muted">Se eliminarán todos los datos asociados a este usuario.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar Usuario
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(userId, userName) {
            document.getElementById('deleteUserName').textContent = userName;
            var deleteForm = document.getElementById('deleteForm');
            deleteForm.action = '@Url.Action("Delete", "UserManagement")/' + userId;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }
    </script>
}
