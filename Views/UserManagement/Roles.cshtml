@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Gestión de Roles";
    var totalRoles = Model.Count();
    var systemRoles = Model.Count(r => r.Name == "Admin" || r.Name == "User");
    var customRoles = totalRoles - systemRoles;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-shield-check me-2" viewBox="0 0 16 16">
            <path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/>
            <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0"/>
        </svg>
        @ViewData["Title"]
    </h2>
    <a asp-action="Index" class="btn btn-secondary btn-lg">
        <i class="bi bi-arrow-left me-2"></i> Volver a Usuarios
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Tarjetas de Resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-primary shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-primary mb-0">@totalRoles</h3>
                <p class="text-muted mb-0">Total Roles</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-info shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-info mb-0">@systemRoles</h3>
                <p class="text-muted mb-0">Roles del Sistema</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success shadow-sm" style="border-width: 2px;">
            <div class="card-body text-center">
                <h3 class="display-4 text-success mb-0">@customRoles</h3>
                <p class="text-muted mb-0">Roles Personalizados</p>
            </div>
        </div>
    </div>
</div>

<!-- Crear Nuevo Rol -->
<div class="card shadow-sm mb-4 border-primary" style="border-width: 2px;">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
            <i class="bi bi-plus-circle me-2"></i>
            Crear Nuevo Rol
        </h5>
    </div>
    <div class="card-body">
        <form asp-action="CreateRole" method="post">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-bold">Nombre del Rol</label>
                    <input type="text" name="roleName" class="form-control form-control-lg" placeholder="Ej: Manager, Supervisor, Editor..." required />
                    <small class="text-muted">El nombre debe ser único y descriptivo</small>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-plus-circle me-2"></i> Crear Rol
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Tabla de Roles -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tipo</th>
                        <th>Nombre del Rol</th>
                        <th>ID</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-shield" style="font-size: 3rem;"></i>
                                <p class="mt-2">No hay roles disponibles</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var role in Model)
                        {
                            var isSystem = role.Name == "Admin" || role.Name == "User";
                            var typeClass = isSystem ? "info" : "success";
                            var typeText = isSystem ? "SISTEMA" : "PERSONALIZADO";
                            var roleClass = role.Name == "Admin" ? "danger" : "primary";
                            
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-@typeClass">
                                        <i class="bi bi-@(isSystem ? "gear-fill" : "star-fill") me-1"></i>
                                        @typeText
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-@roleClass fs-6">
                                        <i class="bi bi-shield-@(role.Name == "Admin" ? "fill-check" : "check") me-1"></i>
                                        @role.Name
                                    </span>
                                </td>
                                <td>
                                    <small class="text-muted font-monospace">@role.Id.Substring(0, 8)...</small>
                                </td>
                                <td>
                                    @if (isSystem)
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-lock-fill me-1"></i>
                                            Protegido
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-unlock me-1"></i>
                                            Editable
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!isSystem)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDeleteRole('@role.Id', '@role.Name')" title="Eliminar">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Rol del sistema protegido">
                                            <i class="bi bi-lock"></i> Protegido
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Confirmar Eliminación de Rol
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas eliminar el rol <strong id="deleteRoleName"></strong>?</p>
                <p class="text-danger"><strong>Esta acción no se puede deshacer.</strong></p>
                <p class="text-muted">Los usuarios que tengan este rol lo perderán.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="deleteRoleForm" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Eliminar Rol
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDeleteRole(roleId, roleName) {
            document.getElementById('deleteRoleName').textContent = roleName;
            var deleteForm = document.getElementById('deleteRoleForm');
            deleteForm.action = '@Url.Action("DeleteRole", "UserManagement")/' + roleId;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteRoleModal'));
            deleteModal.show();
        }
    </script>
}
